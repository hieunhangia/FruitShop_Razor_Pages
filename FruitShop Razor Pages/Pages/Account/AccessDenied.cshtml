@page

@{
    ViewData["Title"] = "Truy cập bị từ chối";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-success text-white text-center py-4 border-0 rounded-top-4">
                <h4 class="mb-0 fw-bold">Từ chối truy cập</h4>
            </div>
            <div class="card-body p-4 p-md-5 text-center">
                <div class="alert alert-danger rounded-3 mb-4">
                    <h5 class="alert-heading fw-bold mb-2">Không có quyền truy cập!</h5>
                    <p class="mb-0">Tài khoản của bạn không được cấp quyền để xem nội dung hoặc thực hiện thao tác tại
                        trang này.</p>
                </div>

                <p class="text-muted mb-4 small">Vui lòng kiểm tra lại đường dẫn hoặc đăng nhập bằng tài khoản có thẩm
                    quyền.</p>

                <div class="d-flex justify-content-center gap-3">
                    <a asp-page="/Everyone/Index" class="btn btn-success fw-bold rounded-pill px-4 shadow-sm">Quay
                        lại trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</div>