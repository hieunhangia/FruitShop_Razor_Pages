@page
@model FruitShop_Razor_Pages.Pages.Account.CreatePassword

@{
    ViewData["Title"] = "Thiết lập mật khẩu";
}

<div class="row mt-4">
    <div class="col-md-3 mb-4">
        <div class="list-group shadow-sm rounded-3">
            <a asp-page="./ManageAccount" class="list-group-item list-group-item-action text-success fw-medium">
                Quản lý tài khoản
            </a>
            <a asp-page="./ChangePassword"
               class="list-group-item list-group-item-action text-success fw-medium">
                Đổi mật khẩu
            </a>
            <a asp-page="CreatePassword"
               class="list-group-item list-group-item-action active bg-success border-success fw-bold">
                Thiết lập mật khẩu
            </a>
        </div>
    </div>
    <div class="col-md-9">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom py-3">
                <h4 class="mb-0 fw-bold text-success">Đổi mật khẩu</h4>
            </div>
            <div class="card-body p-4 p-md-5">

                <form method="post" class="w-100" style="max-width: 500px;">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-medium" role="alert"></div>
                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label fw-semibold text-dark">Mật khẩu mới</label>
                        <input asp-for="Input.Password" class="form-control border-success-subtle bg-light"
                               placeholder="Nhập mật khẩu mới"/>
                        <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold text-dark">Xác nhận mật
                            khẩu mới</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control border-success-subtle bg-light"
                               placeholder="Nhập lại mật khẩu mới"/>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-success fw-bold rounded-pill px-4 shadow-sm">Thiết lập mật
                            khẩu
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>