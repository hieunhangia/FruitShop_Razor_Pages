@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-success text-white text-center py-4 border-0 rounded-top-4">
                <h4 class="mb-0 fw-bold">Đăng nhập</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success rounded-3">@TempData["SuccessMessage"]</div>
                }

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-medium" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label fw-semibold text-success">Email</label>
                        <input asp-for="Input.Email" class="form-control form-control-lg border-success-subtle bg-light"
                               placeholder="Nhập địa chỉ email"/>
                        <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label fw-semibold text-success">Mật khẩu</label>
                        <input asp-for="Input.Password"
                               class="form-control form-control-lg border-success-subtle bg-light"
                               placeholder="Nhập mật khẩu"/>
                        <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4 form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input border-success"/>
                        <label asp-for="Input.RememberMe" class="form-check-label text-muted user-select-none">Nhớ đăng
                            nhập?</label>
                    </div>

                    <div class="d-grid mt-2 mb-4">
                        <button type="submit" class="btn btn-success btn-lg fw-bold rounded-pill shadow-sm">Đăng nhập
                        </button>
                    </div>
                </form>

                <div class="text-center">
                    <a asp-page="Register"
                       class="text-success text-decoration-none fw-medium d-block mb-3 p-2 bg-light-green rounded-3">Chưa
                        có tài khoản? Đăng ký ngay</a>
                    <div class="d-flex justify-content-center gap-3 small">
                        <a asp-page="ForgotPassword" class="text-muted text-decoration-none border-end pe-3">Quên mật
                            khẩu?</a>
                        <a asp-page="ResendConfirmEmail" class="text-muted text-decoration-none">Gửi lại email xác
                            nhận</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
