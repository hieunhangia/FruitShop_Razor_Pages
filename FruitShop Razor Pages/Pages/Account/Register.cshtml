@page
@model RegisterModel
@using Repository

@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-success text-white text-center py-4 border-0 rounded-top-4">
                <h4 class="mb-0 fw-bold">Đăng ký tài khoản</h4>
            </div>
            <div class="card-body p-4 p-md-5">

                <div class="bg-success bg-opacity-10 rounded-3 p-3 mb-4 text-center">
                    <span class="fw-medium text-success">
                        🎁 Đăng ký để nhận ngay <strong>@BusinessRuleConstants.LoyaltyPoint.LoyaltyPointEarnedWhenRegister điểm thưởng</strong>!
                    </span>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-medium" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label fw-semibold text-success">Email</label>
                        <input asp-for="Input.Email" class="form-control form-control-lg border-success-subtle bg-light"
                               placeholder="Nhập địa chỉ email"/>
                        <span asp-validation-for="Input.Email" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label fw-semibold text-success">Mật khẩu</label>
                        <input asp-for="Input.Password"
                               class="form-control form-control-lg border-success-subtle bg-light"
                               placeholder="Nhập mật khẩu"/>
                        <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold text-success">Xác nhận mật
                            khẩu</label>
                        <input asp-for="Input.ConfirmPassword"
                               class="form-control form-control-lg border-success-subtle bg-light"
                               placeholder="Nhập lại mật khẩu"/>
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-grid mt-2 mb-4">
                        <button type="submit" class="btn btn-success btn-lg fw-bold rounded-pill shadow-sm">Đăng ký
                            <span
                                class="d-block fw-normal small opacity-75">🎁 Nhận @BusinessRuleConstants.LoyaltyPoint.LoyaltyPointEarnedWhenRegister điểm thưởng</span>
                        </button>
                    </div>
                </form>

                <div class="text-center">
                    <span class="text-muted">Đã có tài khoản?</span>
                    <a asp-page="Login"
                       class="text-success text-decoration-none fw-medium ms-1 p-2 bg-success bg-opacity-10 rounded-3 px-3">Đăng
                        nhập</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
