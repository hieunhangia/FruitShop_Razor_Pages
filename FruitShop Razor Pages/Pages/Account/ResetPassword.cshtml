@page
@model ResetPasswordModel

@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-success text-white text-center py-4 border-0 rounded-top-4">
                <h4 class="mb-0 fw-bold">Đặt lại mật khẩu</h4>
            </div>
            @if (ViewData["Error"] != null)
            {
                <div class="card-body p-4 p-md-5">
                    <div class="alert alert-danger mb-3 text-center">
                        @ViewData["Error"]
                    </div>
                    <div class="d-grid">
                        <a asp-page="/Everyone/Index" class="btn btn-outline-success fw-bold rounded-pill px-4 mt-2">Về
                            trang chủ</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card-body p-4 p-md-5">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-medium"
                             role="alert"></div>
                        <div class="mb-4">
                            <label asp-for="Input.Password" class="form-label fw-semibold text-success">Nhập mật khẩu
                                mới</label>
                            <input asp-for="Input.Password"
                                   class="form-control form-control-lg border-success-subtle bg-light"
                                   placeholder="Nhập mật khẩu mới"/>
                            <span asp-validation-for="Input.Password" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold text-success">Xác nhận
                                mật khẩu mới</label>
                            <input asp-for="Input.ConfirmPassword"
                                   class="form-control form-control-lg border-success-subtle bg-light"
                                   placeholder="Nhập lại mật khẩu mới"/>
                            <span asp-validation-for="Input.ConfirmPassword"
                                  class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-success btn-lg fw-bold rounded-pill shadow-sm">Đặt lại
                                mật khẩu
                            </button>
                        </div>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}
