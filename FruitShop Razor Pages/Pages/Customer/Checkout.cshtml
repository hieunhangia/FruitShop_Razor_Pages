@page
@using Repository.Constants
@model CheckoutModel

@{
    ViewData["Title"] = "Thanh toán";
}

<div class="container-fluid px-0 py-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h2 class="fw-bold text-success mb-0">Thanh toán đơn hàng</h2>
            <p class="text-muted">Vui lòng kiểm tra thông tin và hoàn tất đặt hàng</p>
        </div>
    </div>

    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="row g-4">
            <!-- Left Column: Order Items -->
            <div class="col-lg-7">
                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-success text-white py-3 rounded-top-4 border-0">
                        <h5 class="card-title mb-0 fw-bold d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                 class="me-2" viewBox="0 0 16 16">
                                <path
                                    d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .49.598l-1 5a.5.5 0 0 1-.465.401l-9.397.472L4.415 11H13a.5.5 0 0 1 0 1H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l.84 4.479 9.144-.459L13.89 4zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4m-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                            </svg>
                            Thông tin sản phẩm
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush rounded-bottom-4 product-list-scroll">
                            @foreach (var item in Model.ProductItems)
                            {
                                <li class="list-group-item p-3">
                                    <div class="d-flex align-items-center">
                                        <img src="@item.ImageUrl" alt="@item.Name"
                                             class="rounded-3 shadow-sm object-fit-cover border product-image"/>
                                        <div class="ms-3 flex-grow-1">
                                            <h6 class="mb-1 fw-bold text-dark fs-5">@item.Name</h6>
                                            <div class="d-flex justify-content-between align-items-center mt-2">
                                                <span class="text-muted">@item.Price.ToString("N0") đ <span
                                                        class="mx-1">x</span> @item.Quantity @item.ProductUnitName</span>
                                                <span
                                                    class="fw-bold text-success fs-5">@((item.Price * item.Quantity).ToString("N0")) đ</span>
                                            </div>
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Right Column: Checkout Form -->
            <div class="col-lg-5">
                <div class="card shadow-sm border-0 rounded-4 sticky-top sticky-checkout-card">
                    <div class="card-body p-4">

                        <!-- Shipping Address -->
                        <h5 class="fw-bold text-success mb-3 d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                 class="me-2" viewBox="0 0 16 16">
                                <path
                                    d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10m0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6"/>
                                <path d="M8 8a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm0-1a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
                            </svg>
                            Địa chỉ giao hàng
                        </h5>

                        @if (Model.ShippingAddresses.Any())
                        {
                            <div class="mb-3 px-2 address-selection-scroll border rounded-3">
                                @foreach (var address in Model.ShippingAddresses)
                                {
                                    <label class="d-block card mb-2 border rounded-3 address-card">
                                        <div class="card-body p-3 d-flex">
                                            <div class="form-check mt-1">
                                                <input class="form-check-input flex-shrink-0" type="radio"
                                                       asp-for="SelectedAddressId" checked="@address.IsDefault"
                                                       value="@address.Id">
                                            </div>
                                            <div class="ms-2 flex-grow-1">
                                                <div class="d-flex justify-content-between align-items-center mb-1">
                                                    <span class="fw-bold">@address.RecipientName</span>
                                                    <span class="fw-bold text-dark">@address.RecipientPhoneNumber</span>
                                                </div>
                                                <p class="text-muted small mb-1 lh-sm">@address.SpecificAddress, @address.CommuneName, @address.ProvinceName</p>
                                                @if (address.IsDefault)
                                                {
                                                    <span
                                                        class="badge bg-success-subtle text-success rounded-pill mt-1">Mặc định</span>
                                                }
                                            </div>
                                        </div>
                                    </label>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning rounded-3 mb-3 small border-warning-subtle">
                                Không có địa chỉ giao hàng nào được lưu. Vui lòng thêm địa chỉ để tiếp tục.
                            </div>
                            <input type="radio" asp-for="SelectedAddressId" value="" class="visually-hidden"/>
                        }
                        <span asp-validation-for="SelectedAddressId" class="text-danger small d-block mb-2"></span>
                        <a asp-page="/Customer/ShippingAddress/Add"
                           class="btn btn-outline-success w-100 rounded-pill btn-sm mb-4 fw-medium">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                 class="me-1 mb-1" viewBox="0 0 16 16">
                                <path fill-rule="evenodd"
                                      d="M8 2a.5.5 0 0 1 .5.5v5h5a.5.5 0 0 1 0 1h-5v5a.5.5 0 0 1-1 0v-5h-5a.5.5 0 0 1 0-1h5v-5A.5.5 0 0 1 8 2Z"/>
                            </svg>
                            Thêm địa chỉ mới
                        </a>

                        <!-- Payment Method -->
                        <h5 class="fw-bold text-success mb-3 mt-2 d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                 class="me-2" viewBox="0 0 16 16">
                                <path
                                    d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v1h14V4a1 1 0 0 0-1-1H2zm13 4H1v5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V7z"/>
                                <path d="M2 10a1 1 0 1 0 0-2 1 1 0 0 0 0 2z"/>
                            </svg>
                            Phương thức thanh toán
                        </h5>

                        <div class="mb-4">
                            <select asp-for="PaymentMethod" class="form-select rounded-pill border-success-subtle">
                                <option value="">-- Chọn phương thức thanh toán --</option>
                                <option value="@PaymentMethod.CashOnDelivery">Thanh toán khi nhận hàng (COD)</option>
                                <option value="@PaymentMethod.QRCode">Chuyển khoản qua mã QR</option>
                            </select>
                            <span asp-validation-for="PaymentMethod" class="text-danger small d-block mt-1"></span>
                        </div>

                        <hr class="my-4 text-muted">

                        <!-- Total & Submit -->
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <span class="text-dark fw-bold fs-5">Tổng thanh toán</span>
                            <span
                                class="fs-3 fw-bold text-success">@Model.ProductItems.Sum(pi => pi.Price * pi.Quantity).ToString("N0") đ</span>
                        </div>

                        <button type="submit"
                                class="btn btn-success w-100 rounded-pill py-3 fw-bold fs-5 shadow-sm text-uppercase">
                            Xác nhận đặt hàng
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}