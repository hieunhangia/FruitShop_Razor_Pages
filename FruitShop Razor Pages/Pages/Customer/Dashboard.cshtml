@page
@using System.Text.Json
@using Repository.Constants
@model FruitShop_Razor_Pages.Pages.Customer.Dashboard.IndexModel
@{
    ViewData["Title"] = "Tổng quan tài khoản của tôi";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-success mb-1 d-flex align-items-center">
                <i class="bi bi-person-circle me-2 text-success fs-3"></i>
                Tổng quan tài khoản của tôi
            </h2>
            <p class="text-muted mb-0">Thống kê hoạt động mua sắm và điểm thưởng cá nhân</p>
        </div>
        <button onclick="location.reload()" class="btn btn-outline-success rounded-pill px-4 fw-medium shadow-sm">
            <i class="bi bi-arrow-clockwise me-2"></i>Làm mới
        </button>
    </div>

    <!-- Row 1: KPI Cards -->
    <div class="row g-4 mb-4">
        <div class="col-lg col-md-6">
            <div class="card border-0 rounded-4 shadow-sm bg-success bg-opacity-10 border-start border-5 border-success h-100 hover-lift">
                <div class="card-body p-4 text-center">
                    <div class="text-success mb-2"><i class="bi bi-bag-check fs-1"></i></div>
                    <h6 class="text-muted fw-medium text-uppercase small mb-1" style="letter-spacing:.5px;">Tổng đơn hàng</h6>
                    <h2 class="display-5 fw-bold text-success mb-0">@Model.DashboardData.KPIs.TotalOrders</h2>
                </div>
            </div>
        </div>
        <div class="col-lg col-md-6">
            <div class="card border-0 rounded-4 shadow-sm bg-primary bg-opacity-10 border-start border-5 border-primary h-100 hover-lift">
                <div class="card-body p-4 text-center">
                    <div class="text-primary mb-2"><i class="bi bi-currency-exchange fs-1"></i></div>
                    <h6 class="text-muted fw-medium text-uppercase small mb-1" style="letter-spacing:.5px;">Tổng chi tiêu</h6>
                    <h4 class="fw-bold text-primary mb-0">@Model.DashboardData.KPIs.TotalSpent.ToString("N0") ₫</h4>
                </div>
            </div>
        </div>
        <div class="col-lg col-md-6">
            <div class="card border-0 rounded-4 shadow-sm bg-warning bg-opacity-10 border-start border-5 border-warning h-100 hover-lift">
                <div class="card-body p-4 text-center">
                    <div class="text-warning mb-2"><i class="bi bi-star-fill fs-1"></i></div>
                    <h6 class="text-muted fw-medium text-uppercase small mb-1" style="letter-spacing:.5px;">Điểm tích luỹ</h6>
                    <h2 class="display-5 fw-bold text-warning mb-0">@Model.DashboardData.KPIs.LoyaltyPoints.ToString("N0")</h2>
                </div>
            </div>
        </div>
        <div class="col-lg col-md-6">
            <div class="card border-0 rounded-4 shadow-sm bg-info bg-opacity-10 border-start border-5 border-info h-100 hover-lift">
                <div class="card-body p-4 text-center">
                    <div class="text-info mb-2"><i class="bi bi-hourglass-split fs-1"></i></div>
                    <h6 class="text-muted fw-medium text-uppercase small mb-1" style="letter-spacing:.5px;">Đơn đang xử lý</h6>
                    <h2 class="display-5 fw-bold text-info mb-0">@Model.DashboardData.KPIs.ActiveOrders</h2>
                </div>
            </div>
        </div>
        <div class="col-lg col-md-6">
            <div class="card border-0 rounded-4 shadow-sm bg-danger bg-opacity-10 border-start border-5 border-danger h-100 hover-lift">
                <div class="card-body p-4 text-center">
                    <div class="text-danger mb-2"><i class="bi bi-ticket-perforated fs-1"></i></div>
                    <h6 class="text-muted fw-medium text-uppercase small mb-1" style="letter-spacing:.5px;">Coupon khả dụng</h6>
                    <h2 class="display-5 fw-bold text-danger mb-0">@Model.DashboardData.KPIs.AvailableCoupons</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 2: Chart + Quick Links -->
    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-bar-chart-line me-2 text-success"></i>Chi tiêu 6 tháng gần nhất</h5>
                </div>
                <div class="card-body p-4">
                    <div style="height: 280px;">
                        <canvas id="spentBarChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-4 h-100">
                <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-lightning-charge me-2 text-warning"></i>Truy cập nhanh</h5>
                </div>
                <div class="card-body p-4 d-flex flex-column gap-3">
                    <a asp-page="/Customer/Order/OrderHistory" class="btn btn-outline-primary rounded-3 py-3 d-flex align-items-center fw-medium hover-lift text-decoration-none text-dark">
                        <i class="bi bi-clock-history fs-4 me-3 text-primary"></i>
                        <div class="text-start">
                            <div class="fw-bold">Lịch sử đơn hàng</div>
                            <small class="text-muted fw-normal">Xem tất cả đơn hàng của tôi</small>
                        </div>
                    </a>
                    <a asp-page="/Customer/Coupon/View" class="btn btn-outline-danger rounded-3 py-3 d-flex align-items-center fw-medium hover-lift text-decoration-none text-dark">
                        <i class="bi bi-ticket-perforated fs-4 me-3 text-danger"></i>
                        <div class="text-start">
                            <div class="fw-bold">Coupon của tôi</div>
                            <small class="text-muted fw-normal">Xem mã giảm giá đang có</small>
                        </div>
                    </a>
                    <a asp-page="/Customer/ShippingAddress/Manage" class="btn btn-outline-success rounded-3 py-3 d-flex align-items-center fw-medium hover-lift text-decoration-none text-dark">
                        <i class="bi bi-geo-alt fs-4 me-3 text-success"></i>
                        <div class="text-start">
                            <div class="fw-bold">Địa chỉ giao hàng</div>
                            <small class="text-muted fw-normal">Quản lý địa chỉ nhận hàng</small>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Row 3: Recent Orders -->
    <div class="row g-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-2 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold text-dark mb-0"><i class="bi bi-receipt me-2 text-primary"></i>5 đơn hàng gần nhất</h5>
                    <a asp-page="/Customer/Order/OrderHistory" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-medium">Xem tất cả</a>
                </div>
                <div class="card-body p-4">
                    @if (!Model.DashboardData.RecentOrders.Any())
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            Bạn chưa có đơn hàng nào. <a asp-page="/Everyone/Product/ExploreProduct">Khám phá sản phẩm</a> ngay!
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-muted small">
                                    <tr>
                                        <th>Mã đơn</th>
                                        <th>Ngày đặt</th>
                                        <th>Trạng thái</th>
                                        <th>Thanh toán</th>
                                        <th class="text-end">Tổng tiền</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.DashboardData.RecentOrders)
                                    {
                                        <tr>
                                            <td class="fw-bold text-muted">#@order.Id</td>
                                            <td class="small">@order.OrderDate.ToString("HH:mm dd/MM/yyyy")</td>
                                            <td>
                                                @{
                                                    var (badgeColor, badgeLabel) = order.OrderStatus switch
                                                    {
                                                        OrderStatus.PendingConfirmation => ("warning", "Chờ xác nhận"),
                                                        OrderStatus.PendingPayment => ("secondary", "Chờ thanh toán"),
                                                        OrderStatus.Processing => ("primary", "Đang xử lý"),
                                                        OrderStatus.Shipping => ("info", "Đang giao"),
                                                        OrderStatus.Delivered => ("success", "Đã giao"),
                                                        OrderStatus.Cancelled => ("danger", "Đã huỷ"),
                                                        _ => ("secondary", order.OrderStatus.ToString())
                                                    };
                                                }
                                                <span class="badge bg-@badgeColor rounded-pill">@badgeLabel</span>
                                            </td>
                                            <td class="small">
                                                @(order.PaymentMethod == PaymentMethod.CashOnDelivery ? "COD" : "QR Code")
                                            </td>
                                            <td class="text-end fw-bold">@order.TotalAmount.ToString("N0") ₫</td>
                                            <td class="text-end">
                                                <a asp-page="/Customer/Order/OrderDetail" asp-route-id="@order.Id"
                                                   class="btn btn-sm btn-outline-secondary rounded-pill">Chi tiết</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-4px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.12) !important;
    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        Chart.defaults.font.family = "'Segoe UI', Roboto, Helvetica, Arial, sans-serif";

        const spentData = @Html.Raw(JsonSerializer.Serialize(Model.DashboardData.SpentChart));
        new Chart(document.getElementById('spentBarChart').getContext('2d'), {
            type: 'bar',
            data: {
                labels: spentData.map(x => x.Label),
                datasets: [{
                    label: 'Chi tiêu (₫)',
                    data: spentData.map(x => x.TotalSpent),
                    backgroundColor: spentData.map(x => x.TotalSpent > 0 ? 'rgba(25,135,84,0.7)' : 'rgba(200,200,200,0.4)'),
                    borderColor: '#198754',
                    borderWidth: 1,
                    borderRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { callback: v => (v / 1000000).toFixed(1) + 'M ₫' },
                        grid: { color: 'rgba(0,0,0,0.05)' }
                    },
                    x: { grid: { display: false } }
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.parsed.y.toLocaleString('vi-VN') + ' ₫'
                        }
                    }
                }
            }
        });
    });
</script>
