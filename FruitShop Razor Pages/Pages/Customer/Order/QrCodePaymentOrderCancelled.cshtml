@page
@model QrCodePaymentOrderCancelledModel

@{
    ViewData["Title"] = "Đã hủy đơn hàng";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4 text-center p-4 p-md-5">
                @if (ViewData["ErrorMessage"] != null)
                {
                    <div class="mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor"
                             class="text-danger" viewBox="0 0 16 16">
                            <path
                                d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767L8.982 1.566zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5zm.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                        </svg>
                    </div>
                    <h2 class="fw-bold text-danger mb-3">Có lỗi xảy ra</h2>
                    <p class="text-muted fs-5 mb-4">@ViewData["ErrorMessage"]</p>
                }
                else
                {
                    <div class="mb-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor"
                             class="text-warning" viewBox="0 0 16 16">
                            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                            <path
                                d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708z"/>
                        </svg>
                    </div>
                    <h2 class="fw-bold text-warning mb-3">Đơn hàng đã bị hủy</h2>
                    <p class="text-muted fs-5 mb-4">Giao dịch thanh toán QR không thành công hoặc đã bị bạn hủy bỏ.</p>
                }

                <div class="d-grid gap-3 d-sm-flex justify-content-sm-center mt-2">
                    <a asp-page="/Guest/Homepage" class="btn btn-success rounded-pill px-5 py-2 fw-medium shadow-sm btn-fruit">Về
                        trang chủ</a>
                </div>
            </div>
        </div>
    </div>
</div>