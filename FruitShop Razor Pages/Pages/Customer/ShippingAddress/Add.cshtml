@page
@model AddModel

@{
    ViewData["Title"] = "Thêm địa chỉ giao hàng";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-success text-white text-center py-4 border-0 rounded-top-4">
                <h4 class="mb-0 fw-bold">Thêm địa chỉ mới</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-medium" role="alert"></div>
                    <input type="hidden" asp-for="ReturnUrl"/>
                    <div class="mb-3">
                        <label asp-for="Input.RecipientName" class="form-label fw-semibold text-dark">Tên người
                            nhận</label>
                        <input asp-for="Input.RecipientName" class="form-control border-success-subtle bg-light"
                               placeholder="Nhập tên người nhận"/>
                        <span asp-validation-for="Input.RecipientName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.RecipientPhoneNumber" class="form-label fw-semibold text-dark">Số điện
                            thoại</label>
                        <input asp-for="Input.RecipientPhoneNumber" class="form-control border-success-subtle bg-light"
                               placeholder="Nhập số điện thoại"/>
                        <span asp-validation-for="Input.RecipientPhoneNumber"
                              class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="Input.ProvinceCode" class="form-label fw-semibold text-dark">Tỉnh/thành
                                phố</label>
                            <select asp-for="Input.ProvinceCode" class="form-select border-success-subtle bg-light">
                                <option value="">-- Chọn tỉnh/thành phố --</option>
                            </select>
                            <span asp-validation-for="Input.ProvinceCode" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.CommuneCode"
                                   class="form-label fw-semibold text-dark">Xã/phường</label>
                            <select asp-for="Input.CommuneCode" class="form-select border-success-subtle bg-light">
                                <option value="">-- Chọn xã/phường --</option>
                            </select>
                            <span asp-validation-for="Input.CommuneCode" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.SpecificAddress" class="form-label fw-semibold text-dark">Địa chỉ cụ
                            thể</label>
                        <input asp-for="Input.SpecificAddress" class="form-control border-success-subtle bg-light"
                               placeholder="Số nhà, tên đường..."/>
                        <span asp-validation-for="Input.SpecificAddress" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <button type="button" onclick="history.back()"
                                class="btn btn-outline-secondary rounded-pill px-4 fw-medium w-50">Hủy
                        </button>
                        <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm w-50">Lưu địa
                            chỉ
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>

    <script src="~/js/address.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            initAddressDropdowns("Input_ProvinceCode", "Input_CommuneCode");
        });
    </script>
}