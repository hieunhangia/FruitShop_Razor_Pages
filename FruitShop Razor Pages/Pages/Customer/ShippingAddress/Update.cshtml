@page
@model UpdateModel

@{
    ViewData["Title"] = "Cập nhật địa chỉ giao hàng";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0 rounded-4">
            <div class="card-header bg-success text-white text-center py-4 border-0 rounded-top-4">
                <h4 class="mb-0 fw-bold">Cập nhật địa chỉ</h4>
            </div>
            <div class="card-body p-4 p-md-5">
                @if (ViewData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger rounded-3 shadow-sm mb-4">@ViewData["ErrorMessage"]</div>
                }

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-medium" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="Input.RecipientName" class="form-label fw-semibold text-dark">Tên người
                            nhận</label>
                        <input asp-for="Input.RecipientName" class="form-control border-success-subtle bg-light"
                               placeholder="Nhập tên người nhận"/>
                        <span asp-validation-for="Input.RecipientName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Input.RecipientPhoneNumber" class="form-label fw-semibold text-dark">Số điện
                            thoại</label>
                        <input asp-for="Input.RecipientPhoneNumber" class="form-control border-success-subtle bg-light"
                               placeholder="Nhập số điện thoại"/>
                        <span asp-validation-for="Input.RecipientPhoneNumber"
                              class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="Input.ProvinceCode" class="form-label fw-semibold text-dark">Tỉnh/thành
                                phố</label>
                            <select asp-for="Input.ProvinceCode" class="form-select border-success-subtle bg-light">
                                <option value="">-- Chọn tỉnh/thành phố --</option>
                            </select>
                            <span asp-validation-for="Input.ProvinceCode" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.CommuneCode"
                                   class="form-label fw-semibold text-dark">Xã/phường</label>
                            <select asp-for="Input.CommuneCode" class="form-select border-success-subtle bg-light">
                                <option value="">-- Chọn xã/phường --</option>
                            </select>
                            <span asp-validation-for="Input.CommuneCode" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.SpecificAddress" class="form-label fw-semibold text-dark">Địa chỉ cụ
                            thể</label>
                        <input asp-for="Input.SpecificAddress" class="form-control border-success-subtle bg-light"
                               placeholder="Số nhà, tên đường..."/>
                        <span asp-validation-for="Input.SpecificAddress" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex gap-3 mt-4">
                        <a asp-page="Manage" class="btn btn-outline-secondary rounded-pill px-4 fw-medium w-50">Hủy</a>
                        <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm w-50">Cập
                            nhật
                        </button>
                    </div>
                </form>

                <hr class="my-4 border-secondary-subtle"/>

                @if (Model.IsDefault)
                {
                    <div class="alert alert-success rounded-3 mb-0 text-center fw-medium border-success-subtle">
                        Đây là địa chỉ mặc định của bạn.
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column flex-sm-row gap-3">
                        <form method="post" asp-page-handler="SetDefault" asp-route-id="@Model.Id" class="w-100 m-0">
                            <button type="submit" class="btn btn-outline-success rounded-pill w-100 fw-medium">
                                Đặt làm mặc định
                            </button>
                        </form>

                        <form method="post" asp-page-handler="Delete" asp-route-id="@Model.Id" class="w-100 m-0"
                              onsubmit="return confirm('Bạn có chắc muốn xóa địa chỉ này?');">
                            <button type="submit" class="btn btn-outline-danger rounded-pill w-100 fw-medium">
                                Xóa địa chỉ
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}

<script>
    document.addEventListener("DOMContentLoaded", async function () {
        const provinceSelect = document.getElementById("Input_ProvinceCode");
        const communeSelect = document.getElementById("Input_CommuneCode");

        const currentProvinceCode = '@(Model.Input.ProvinceCode)';
        const currentCommuneCode = '@(Model.Input.CommuneCode)';

        async function fetchProvinces() {
            const response = await fetch('/api/address/provinces');
            const provinces = await response.json();

            provinces.forEach(p => {
                provinceSelect.add(new Option(p.name, p.code));
            });
        }

        async function fetchCommunes(provinceCode) {
            communeSelect.innerHTML = '<option value="">-- Chọn xã/phường --</option>';
            if (!provinceCode) return;
            const response = await fetch(`/api/address/provinces/${provinceCode}/communes`);
            const communes = await response.json();
            communes.forEach(c => {
                communeSelect.add(new Option(c.name, c.code));
            });
        }

        async function initUpdatePage() {
            await fetchProvinces();
            provinceSelect.value = currentProvinceCode;
            await fetchCommunes(currentProvinceCode);
            communeSelect.value = currentCommuneCode;
        }

        await initUpdatePage();
        provinceSelect.addEventListener("change", function () {
            fetchCommunes(this.value);
        });
    });
</script>