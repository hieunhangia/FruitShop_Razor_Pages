@section Scripts {
    <script>
        // Auto-scroll reviews marquee - scrolls left by 1px every 20ms (smooth continuous scroll)
        (function () {
            const marquee = document.getElementById('reviewsMarquee');
            if (!marquee) return;

            let scrollSpeed = 0.8; // pixels per tick
            let isPaused = false;

            // Pause on hover
            marquee.addEventListener('mouseenter', () => isPaused = true);
            marquee.addEventListener('mouseleave', () => isPaused = false);

            function step() {
                if (!isPaused) {
                    marquee.scrollLeft += scrollSpeed;

                    // When we've scrolled past the first set of items, reset to start for infinite loop
                    const halfWidth = marquee.scrollWidth / 2;
                    if (marquee.scrollLeft >= halfWidth) {
                        marquee.scrollLeft -= halfWidth;
                    }
                }
                requestAnimationFrame(step);
            }

            requestAnimationFrame(step);
        })();
    </script>
}