@page "/explore-product"
@using Repository
@using Repository.Constants
@using Repository.Models.Products
@model ExploreProductModel

@{
    ViewData["Title"] = "Khám phá sản phẩm";
}

<div class="container py-5 min-vh-100">
    <div class="row mb-5 align-items-center">
        <div class="col-12 text-center text-md-start">
            <h2 class="fw-bold text-success mb-0 d-flex align-items-center justify-content-center justify-content-md-start">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor"
                     class="bi bi-shop me-3" viewBox="0 0 16 16">
                    <path
                        d="M2.97 1.35A1 1 0 0 1 3.73 1h8.54a1 1 0 0 1 .76.35l2.609 3.044A1.5 1.5 0 0 1 16 5.37v.255a2.375 2.375 0 0 1-4.25 1.458A2.371 2.371 0 0 1 9.875 8 2.37 2.37 0 0 1 8 7.083 2.37 2.37 0 0 1 6.125 8a2.37 2.37 0 0 1-1.875-.917A2.375 2.375 0 0 1 0 5.625V5.37a1.5 1.5 0 0 1 .361-.976l2.61-3.045zm1.78 4.275a1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0 1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0 1.375 1.375 0 1 0 2.75 0V5.37a.5.5 0 0 0-.12-.325L12.27 2H3.73L1.12 5.045A.5.5 0 0 0 1 5.37v.255a1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0zM1.5 8.5A.5.5 0 0 1 2 9v6h1v-5a1 1 0 0 1 1-1h3a1 1 0 0 1 1 1v5h6V9a.5.5 0 0 1 1 0v6h.5a.5.5 0 0 1 0 1H.5a.5.5 0 0 1 0-1H1V9a.5.5 0 0 1 .5-.5zM4 15h3v-5H4v5zm5-5a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3z"/>
                </svg>
                Khám phá sản phẩm
            </h2>
            <p class="text-muted mt-2 mb-0">Tìm kiếm và lựa chọn những sản phẩm tươi ngon nhất</p>
        </div>
    </div>

    <form method="get">
        <div class="row g-4">
            <!-- Sidebar / Filters -->
            <div class="col-lg-3">
                <div class="card border-0 shadow-sm rounded-4 sticky-lg-top" style="top: 2rem; z-index: 10;">
                    <div class="card-header bg-white border-bottom border-light-subtle py-3 rounded-top-4">
                        <h5 class="mb-0 fw-bold d-flex align-items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                 class="bi bi-funnel text-success me-2" viewBox="0 0 16 16">
                                <path
                                    d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2h-11z"/>
                            </svg>
                            Bộ lọc
                        </h5>
                    </div>
                    <div class="card-body p-4">
                        <!-- Search term -->
                        <div class="mb-4">
                            <label asp-for="PagedAndSortedRequest.Filter.SearchTerm"
                                   class="form-label fw-medium text-dark">Từ khóa</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0 text-muted rounded-start-pill ps-3">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                         class="bi bi-search" viewBox="0 0 16 16">
                                        <path
                                            d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                                    </svg>
                                </span>
                                <input asp-for="PagedAndSortedRequest.Filter.SearchTerm"
                                       class="form-control border-start-0 rounded-end-pill shadow-none px-2"
                                       placeholder="Tìm tên sản phẩm..."/>
                            </div>
                        </div>

                        <!-- Category -->
                        <div class="mb-4">
                            <label asp-for="PagedAndSortedRequest.Filter.CategoryId"
                                   class="form-label fw-medium text-dark">Danh mục</label>
                            <select asp-for="PagedAndSortedRequest.Filter.CategoryId"
                                    class="form-select rounded-pill shadow-none text-muted">
                                <option value="">Tất cả danh mục</option>
                                @foreach (var category in Model.Categories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                        </div>

                        <!-- Price range -->
                        <div class="mb-4">
                            <label class="form-label fw-medium text-dark">Khoảng giá (VNĐ)</label>
                            <div class="d-flex align-items-center gap-2">
                                <input asp-for="PagedAndSortedRequest.Filter.MinPrice"
                                       class="form-control rounded-pill shadow-none text-center px-2" placeholder="Từ"
                                       type="number" min="0"/>
                                <span class="text-muted">-</span>
                                <input asp-for="PagedAndSortedRequest.Filter.MaxPrice"
                                       class="form-control rounded-pill shadow-none text-center px-2" placeholder="Đến"
                                       type="number" min="0"/>
                            </div>
                        </div>

                        <!-- Rating -->
                        <div class="mb-4">
                            <label class="form-label fw-medium text-dark">Đánh giá</label>
                            <select asp-for="PagedAndSortedRequest.Filter.AverageRating"
                                    class="form-select rounded-pill shadow-none text-muted">
                                <option value="">Tất cả</option>
                                @for (var i = @BusinessRuleConstants.Model.ProductReview.RatingMinValue; i <= @BusinessRuleConstants.Model.ProductReview.RatingMaxValue; i++)
                                {
                                    var rate = i;
                                    <option value="@i">@rate sao</option>
                                }
                            </select>
                        </div>

                        <hr class="border-light-subtle my-4">

                        <!-- Sort -->
                        <div class="mb-4">
                            <label asp-for="PagedAndSortedRequest.SortColumn" class="form-label fw-medium text-dark">Sắp
                                xếp theo</label>
                            <select asp-for="PagedAndSortedRequest.SortColumn"
                                    class="form-select rounded-pill shadow-none text-muted mb-3">
                                <option value="@nameof(Product.DisplayOrder)">Mặc định</option>
                                <option value="@nameof(Product.Name)">Tên sản phẩm</option>
                                <option value="@nameof(Product.Price)">Giá</option>
                                <option value="BestSelling">Bán chạy nhất</option>
                                <option value="BestRating">Đánh giá</option>
                            </select>

                            <select asp-for="PagedAndSortedRequest.SortDirection"
                                    class="form-select rounded-pill shadow-none text-muted">
                                <option value="@SortDirection.Ascending">Tăng dần</option>
                                <option value="@SortDirection.Descending">Giảm dần</option>
                            </select>
                        </div>

                        <!-- Submit button -->
                        <div class="d-grid mt-4">
                            <button type="submit" name="isSearch" value="true"
                                    class="btn btn-success rounded-pill py-2 fw-bold shadow-sm d-flex align-items-center justify-content-center transition-all hover-shadow">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                     class="me-2" viewBox="0 0 16 16">
                                    <path
                                        d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                                </svg>
                                Lọc sản phẩm
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content: Product Grid -->
            <div class="col-lg-9">
                @if (Model.PagedAndSortedResult?.Items != null && Model.PagedAndSortedResult.Items.Any())
                {
                    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 mb-5">
                        @foreach (var product in Model.PagedAndSortedResult.Items)
                        {
                            <div class="col">
                                <partial name="_ProductCard" model="product"/>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    @if (Model.PagedAndSortedResult.TotalPages > 1)
                    {
                        <div
                            class="d-flex flex-column flex-md-row justify-content-between align-items-center bg-white p-4 rounded-4 shadow-sm border-0">
                            <div class="mb-3 mb-md-0 text-muted">
                                Hiển thị trang <span
                                    class="fw-bold text-success fs-5 mx-1">@Model.PagedAndSortedResult.PageIndex</span>
                                /
                                <span class="fw-bold text-dark mx-1">@Model.PagedAndSortedResult.TotalPages</span>
                            </div>

                            <div class="d-flex flex-wrap gap-3 align-items-center justify-content-center">
                                <div class="btn-group shadow-sm overflow-hidden">
                                    @if (Model.PagedAndSortedResult.HasPreviousPage)
                                    {
                                        <button type="submit" name="PagedAndSortedRequest.PageIndex"
                                                value="@(Model.PagedAndSortedResult.PageIndex - 1)"
                                                class="btn btn-outline-success px-4 py-2 fw-medium border-end-0">
                                            &laquo; Trước
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-outline-secondary disabled px-4 py-2 fw-medium border-end-0 bg-light">
                                            &laquo; Trước
                                        </button>
                                    }

                                    @if (Model.PagedAndSortedResult.HasNextPage)
                                    {
                                        <button type="submit" name="PagedAndSortedRequest.PageIndex"
                                                value="@(Model.PagedAndSortedResult.PageIndex + 1)"
                                                class="btn btn-outline-success px-4 py-2 fw-medium border-start-0">
                                            Sau &raquo;
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-outline-secondary disabled px-4 py-2 fw-medium border-start-0 bg-light">
                                            Sau &raquo;
                                        </button>
                                    }
                                </div>

                                <div
                                    class="d-flex align-items-center bg-light rounded-pill p-1 border border-light-subtle">
                                    <span class="text-muted small mx-3 fw-medium text-nowrap">Đến trang:</span>
                                    <div class="input-group input-group-sm rounded-pill" style="width: 130px;">
                                        <input asp-for="PagedAndSortedRequest.PageIndex"
                                               class="form-control text-center border-success shadow-none rounded-start-pill bg-white"
                                               min="1"
                                               max="@Model.PagedAndSortedResult.TotalPages"
                                               value="@Model.PagedAndSortedResult.PageIndex"
                                               style="height: 38px;"/>
                                        <button type="submit"
                                                class="btn btn-success fw-bold rounded-end-pill px-3 shadow-none"
                                                style="height: 38px;">Đi
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <span asp-validation-for="PagedAndSortedRequest.PageIndex"
                              class="text-danger small d-block mt-2 text-end"></span>
                    }
                }
                else
                {
                    <div
                        class="card border-0 shadow-sm rounded-4 text-center py-5 h-100 d-flex flex-column justify-content-center align-items-center">
                        <div class="mb-4">
                            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor"
                                 class="bi bi-search text-muted opacity-25" viewBox="0 0 16 16">
                                <path
                                    d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                            </svg>
                        </div>
                        <h4 class="text-dark fw-bold mb-2">Không tìm thấy sản phẩm nào</h4>
                        <p class="text-muted mb-0">Rất tiếc, không có sản phẩm nào phù hợp với bộ lọc của bạn.</p>
                        <button type="button" class="btn btn-outline-success rounded-pill mt-4 px-4 fw-medium"
                                onclick="window.location.href='@Url.Page("/Everyone/Product/ExploreProduct")'">
                            Xóa bộ lọc
                        </button>
                    </div>
                }
            </div>
        </div>
    </form>
</div>