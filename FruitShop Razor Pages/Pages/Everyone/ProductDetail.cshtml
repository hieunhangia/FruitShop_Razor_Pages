@page "/products/{id:int}"
@model ProductDetailModel

@{
    ViewData["Title"] = Model.Product?.Name ?? "Chi tiết sản phẩm";
}

@if (Model.Product == null)
{
    <div class="alert alert-warning">
        <h4>Không tìm thấy sản phẩm</h4>
        <p>Sản phẩm bạn đang tìm kiếm không tồn tại hoặc đã bị xóa.</p>
        <a asp-page="/Everyone/Homepage" class="btn btn-primary">Quay về trang chủ</a>
    </div>
}
else
{
    <div class="row" style="margin-top: 50px;">
        <div class="col-md-6 mb-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <img src="@Model.Product.ImageUrl"
                     alt="@Model.Product.Name"
                     class="w-100"
                     style="object-fit: cover; max-height: 500px;"/>
            </div>
        </div>

        <div class="col-md-6">
            <h1 class="fw-bold mb-3">@Model.Product.Name</h1>

            <div class="mb-4">
                <span class="text-success fw-bold fs-2">
                    @Model.Product.Price.ToString("N0") ₫
                </span>
                <span class="text-muted">/ @Model.Product.ProductUnitName</span>
            </div>

            <div class="mb-4">
                <h5 class="fw-bold">Mô tả sản phẩm</h5>
                <p class="text-muted">@Model.Product.Description</p>
            </div>
            @if (Model.Product.Categories.Any())
            {
                <div class="mb-4">
                    <h5 class="fw-bold mb-3">Danh mục</h5>
                    <div>
                        @foreach (var category in Model.Product.Categories)
                        {
                            <span class="badge bg-secondary me-2">@category.Name</span>
                        }
                    </div>
                </div>
            }
            <div class="mb-4">
                <p class="mb-2">
                    <strong>Còn lại:</strong>
                    <span
                        class="text-@(Model.Product.Quantity - Model.Product.HeldQuantity > 0 ? "success" : "danger")">
                        @(Model.Product.Quantity - Model.Product.HeldQuantity) @Model.Product.ProductUnitName
                    </span>
                </p>
                <p class="mb-2">
                    <strong>Trạng thái:</strong>
                    <span class="badge bg-@(Model.Product.IsActive ? "success" : "secondary")">
                        @(Model.Product.IsActive ? "Đang bán" : "Ngừng bán")
                    </span>
                </p>
            </div>

            @if (Model.Product.IsActive && (Model.Product.Quantity - Model.Product.HeldQuantity) > 0)
            {
                <div class="d-grid gap-2 w-100">
                    <form method="post" asp-page-handler="AddToCart" asp-route-id="@Model.Product.Id">
                        <button type="submit" class="btn btn-success btn-lg rounded-pill">
                            <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="alert alert-warning">
                    Sản phẩm hiện không có sẵn
                </div>
            }
        </div>
    </div>
}