@page "/products/{productId:int}"
@using Markdig
@model ProductDetail

@{
    ViewData["Title"] = Model.Product?.Name ?? "Chi tiết sản phẩm";
}

@if (Model.Product == null)
{
    <div class="text-center py-5">
        <h3 class="text-muted">Không tìm thấy sản phẩm.</h3>
        <a asp-page="/Everyone/Index" class="btn btn-outline-success mt-3">Quay về trang chủ</a>
    </div>
}
else
{
    <div class="py-4">
        <!-- Breadcrumbs -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a asp-page="/Everyone/Index" class="text-success text-decoration-none">Trang
                        chủ</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Product.Name</li>
            </ol>
        </nav>

        <div class="row g-5 mb-5">
            <!-- Product Image -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden sticky-top" style="top: 2rem;">
                    @if (!string.IsNullOrEmpty(Model.Product.ImageUrl))
                    {
                        <img src="@Model.Product.ImageUrl" alt="@Model.Product.Name" class="img-fluid w-100"
                             style="object-fit: cover; max-height: 500px;"/>
                    }
                    else
                    {
                        <div class="bg-light d-flex align-items-center justify-content-center text-muted"
                             style="height: 400px;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="currentColor"
                                 class="bi bi-image" viewBox="0 0 16 16">
                                <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
                                <path
                                    d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/>
                            </svg>
                            <span class="ms-3 fs-5">Chưa có hình ảnh</span>
                        </div>
                    }
                    @if (!Model.Product.IsActive)
                    {
                        <div
                            class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-50 d-flex align-items-center justify-content-center">
                            <span class="badge bg-danger fs-4 shadow">Ngừng kinh doanh</span>
                        </div>
                    }
                    else if (Model.Product.Quantity <= 0)
                    {
                        <div
                            class="position-absolute top-0 start-0 w-100 h-100 bg-white bg-opacity-50 d-flex align-items-center justify-content-center">
                            <span class="badge bg-secondary fs-4 shadow">Hết hàng</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Product Details -->
            <div class="col-lg-7">
                <h1 class="fw-bold text-dark mb-2">@Model.Product.Name</h1>

                <div class="d-flex align-items-center flex-wrap gap-2 mb-3">
                    @if (Model.Product.Categories.Any())
                    {
                        @foreach (var cat in Model.Product.Categories)
                        {
                            <span
                                class="badge bg-success bg-opacity-10 text-success border border-success-subtle rounded-pill px-3 py-2">@cat.Name</span>
                        }
                    }
                </div>

                <div class="mb-4">
                    <h2 class="text-danger fw-bold mb-0">@Model.Product.Price.ToString("N0") đ <span
                            class="text-muted fs-5 fw-normal">/ @Model.Product.ProductUnitName</span></h2>
                </div>

                @if (Model.Product.IsActive)
                {
                    <form method="post" class="mt-4">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="row align-items-end g-3 mb-4">
                            <div class="col-auto">
                                <label asp-for="AddToCartQuantity" class="form-label text-muted fw-medium small mb-2">Số
                                    lượng</label>
                                <div
                                    class="input-group shadow-sm rounded-pill overflow-hidden border border-light-subtle"
                                    style="width: 140px;">
                                    <button class="btn btn-light border-0" type="button"
                                            onclick="document.getElementById('quantityInput').stepDown()"><span
                                            class="fs-5">-</span></button>
                                    <input asp-for="AddToCartQuantity" id="quantityInput"
                                           class="form-control text-center fw-bold border-0 bg-light" type="number"/>
                                    <button class="btn btn-light border-0" type="button"
                                            onclick="document.getElementById('quantityInput').stepUp()"><span
                                            class="fs-5">+</span></button>
                                </div>
                            </div>
                            <div class="col-auto pb-2">
                                <span class="text-muted small">
                                    Còn lại <b class="text-dark">@Model.Product.Quantity</b> sản phẩm
                                </span>
                            </div>
                        </div>
                        <span asp-validation-for="AddToCartQuantity" class="text-danger small d-block mb-4"></span>

                        <div class="d-flex flex-wrap gap-3">
                            <button type="submit" asp-page-handler="AddToCart"
                                    class="btn btn-outline-success btn-lg px-4 py-3 fw-bold rounded-pill shadow-sm d-flex align-items-center flex-grow-1 flex-md-grow-0 justify-content-center"
                                    disabled="@(Model.Product.Quantity <= 0 ? "disabled" : null)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                     class="me-2" viewBox="0 0 16 16">
                                    <path
                                        d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1H.5zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0zM9 5.5V7h1.5a.5.5 0 0 1 0 1H9v1.5a.5.5 0 0 1-1 0V8H6.5a.5.5 0 0 1 0-1H8V5.5a.5.5 0 0 1 1 0z"/>
                                </svg>
                                Thêm vào giỏ hàng
                            </button>

                            <button type="submit" asp-page-handler="BuyNow"
                                    class="btn btn-success btn-lg px-5 py-3 fw-bold rounded-pill shadow-sm d-flex align-items-center flex-grow-1 flex-md-grow-0 justify-content-center"
                                    disabled="@(Model.Product.Quantity <= 0 ? "disabled" : null)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                     class="me-2" viewBox="0 0 16 16">
                                    <path
                                        d="M2.97 1.35A1 1 0 0 1 3.73 1h8.54a1 1 0 0 1 .76.35l2.609 3.044A1.5 1.5 0 0 1 16 5.37v.255a2.375 2.375 0 0 1-4.25 1.458A2.37 2.37 0 0 1 9.875 8 2.37 2.37 0 0 1 8 7.083 2.37 2.37 0 0 1 6.125 8a2.37 2.37 0 0 1-1.875-.917A2.375 2.375 0 0 1 0 5.625V5.37a1.5 1.5 0 0 1 .361-.976zm1.78 4.275a1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0 1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0 1.375 1.375 0 1 0 2.75 0V5.37a.5.5 0 0 0-.12-.325L12.27 2H3.73L1.12 5.045A.5.5 0 0 0 1 5.37v.255a1.375 1.375 0 0 0 2.75 0 .5.5 0 0 1 1 0M1.5 8.5A.5.5 0 0 1 2 9v6h12V9a.5.5 0 0 1 1 0v6h.5a.5.5 0 0 1 0 1H.5a.5.5 0 0 1 0-1H1V9a.5.5 0 0 1 .5-.5m2 .5a.5.5 0 0 1 .5.5V13h8V9.5a.5.5 0 0 1 1 0V13a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5a.5.5 0 0 1 .5-.5"/>
                                </svg>
                                Mua ngay
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="alert alert-danger rounded-4 mt-4 shadow-sm">
                        <h5 class="fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill me-2"></i>Sản phẩm ngừng kinh
                            doanh</h5>
                        <p class="mb-0">Rất tiếc, sản phẩm này hiện không còn được bán. Vui lòng tham khảo các sản phẩm
                            khác.</p>
                    </div>
                }
            </div>
        </div>

        <!-- Description Section -->
        <div class="mt-5 pt-4 border-top">
            <h3 class="fw-bold text-dark mb-4">Mô tả sản phẩm</h3>
            <div class="card border-light-subtle shadow-sm rounded-4 overflow-hidden position-relative">
                <div class="card-body p-4 p-md-5">
                    <div id="descriptionContent" class="markdown-content text-dark lh-lg"
                         style="max-height: 250px; overflow: hidden; transition: max-height 0.3s ease;">
                        @Html.Raw(Markdown.ToHtml(Model.Product.Description))
                    </div>
                    <!-- Gradient Overlay -->
                    <div id="descriptionOverlay" class="position-absolute bottom-0 start-0 w-100"
                         style="height: 120px; background: linear-gradient(to bottom, rgba(255,255,255,0), rgba(255,255,255,1)); z-index: 10;"></div>
                </div>
                <div class="card-footer bg-white border-0 text-center pb-4 pt-0 position-relative" style="z-index: 11;">
                    <button type="button" id="btnToggleDescription" class="btn btn-outline-success rounded-pill px-4"
                            onclick="toggleDescription()">
                        Đọc thêm
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                             class="bi bi-chevron-down ms-1" viewBox="0 0 16 16">
                            <path fill-rule="evenodd"
                                  d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/>
                        </svg>
                    </button>
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        <div class="mt-5 pt-4">
            <h3 class="fw-bold text-dark mb-4 border-bottom pb-3">Đánh giá sản phẩm
                (@(Model.Product.ProductReviews.Count))</h3>

            @if (Model.Product.ProductReviews.Any())
            {
                <div class="row g-4">
                    @foreach (var review in Model.Product.ProductReviews)
                    {
                        <div class="col-12">
                            <div class="card border-light-subtle shadow-sm rounded-4">
                                <div class="card-body p-4">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div>
                                            <div class="d-flex text-warning mb-2">
                                                @for (var i = 1; i <= 5; i++)
                                                {
                                                    if (i <= review.Rating)
                                                    {
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                             fill="currentColor" class="me-1" viewBox="0 0 16 16">
                                                            <path
                                                                d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                                        </svg>
                                                    }
                                                    else
                                                    {
                                                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                             fill="currentColor" class="me-1 text-muted opacity-25"
                                                             viewBox="0 0 16 16">
                                                            <path
                                                                d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.73 3.522-3.356c.33-.314.16-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.354 5.12l-4.898.696c-.441.062-.612.636-.283.95l3.523 3.356-.83 4.73zm4.905-2.767-3.686 1.894.694-3.957a.565.565 0 0 0-.163-.505L1.71 6.745l4.052-.576a.525.525 0 0 0 .393-.288L8 2.223l1.847 3.658a.525.525 0 0 0 .393.288l4.052.575-2.906 2.77a.565.565 0 0 0-.163.506l.694 3.957-3.686-1.894a.503.503 0 0 0-.461 0z"/>
                                                        </svg>
                                                    }
                                                }
                                            </div>
                                            <span class="text-muted small">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                                                     fill="currentColor" class="bi bi-clock me-1 mb-1"
                                                     viewBox="0 0 16 16">
                                                  <path
                                                      d="M8 3.5a.5.5 0 0 0-1 0V9a.5.5 0 0 0 .252.434l3.5 2a.5.5 0 0 0 .496-.868L8 8.71z"/>
                                                  <path
                                                      d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m7-8A7 7 0 1 1 1 8a7 7 0 0 1 14 0"/>
                                                </svg>
                                                @review.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                            </span>
                                        </div>
                                    </div>
                                    <p class="text-dark mb-0">@review.Comment</p>

                                    @if (!string.IsNullOrEmpty(review.ResolutionMessage))
                                    {
                                        <div class="mt-3 p-3 bg-light rounded-3 border-start border-4 border-success">
                                            <p class="mb-0 text-dark small">@review.ResolutionMessage</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5 bg-light rounded-4 border border-light-subtle">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                         class="text-muted opacity-50 mb-3" viewBox="0 0 16 16">
                        <path
                            d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                    </svg>
                    <p class="text-muted mb-0">Chưa có đánh giá nào cho sản phẩm này.</p>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
    <script>
        function toggleDescription() {
            var content = document.getElementById("descriptionContent");
            var overlay = document.getElementById("descriptionOverlay");
            var btn = document.getElementById("btnToggleDescription");

            if (content.style.maxHeight !== "none") {
                content.style.maxHeight = "none";
                overlay.style.display = "none";
                btn.innerHTML = 'Thu gọn <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-up ms-1" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M7.646 4.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1-.708.708L8 5.707l-5.646 5.647a.5.5 0 0 1-.708-.708l6-6z"/></svg>';
            } else {
                content.style.maxHeight = "250px";
                overlay.style.display = "block";
                btn.innerHTML = 'Đọc thêm <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chevron-down ms-1" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708z"/></svg>';
            }
        }
    </script>
}
