@model Service.DTOs.Everyone.Product.ProductSummaryDto

<div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card"
     style="transition: transform 0.2s ease, box-shadow 0.2s ease;"
     onmouseover="this.style.transform='translateY(-5px)'; this.classList.replace('shadow-sm', 'shadow');"
     onmouseout="this.style.transform='none'; this.classList.replace('shadow', 'shadow-sm');">
    <a asp-page="ProductDetail" asp-route-productId="@Model.Id" class="text-decoration-none">
        <div class="position-relative">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" class="card-img-top"
                     style="height: 220px; object-fit: cover;"/>
            }
            else
            {
                <div class="bg-light d-flex align-items-center justify-content-center text-muted"
                     style="height: 220px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                         class="bi bi-image opacity-50" viewBox="0 0 16 16">
                        <path d="M6.002 5.5a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0z"/>
                        <path
                            d="M2.002 1a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V3a2 2 0 0 0-2-2h-12zm12 1a1 1 0 0 1 1 1v6.5l-3.777-1.947a.5.5 0 0 0-.577.093l-3.71 3.71-2.66-1.772a.5.5 0 0 0-.63.062L1.002 12V3a1 1 0 0 1 1-1h12z"/>
                    </svg>
                </div>
            }
            <div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-10 opacity-0 transition-opacity"
                 onmouseover="this.classList.replace('opacity-0', 'opacity-100')"
                 onmouseout="this.classList.replace('opacity-100', 'opacity-0')"
                 style="transition: opacity 0.2s ease;"></div>
        </div>

        <div class="card-body d-flex flex-column p-4">
            <h5 class="card-title text-dark fw-bold mb-2 text-truncate" title="@Model.Name">@Model.Name</h5>

            <div class="mb-3 d-flex align-items-center gap-2">
                @if (Model.AverageRating.HasValue)
                {
                    <div class="d-flex text-warning">
                        @{
                            var avgRatingVal = Model.AverageRating.Value;
                        }

                        @{
                            var fullStars = (int)Math.Floor(avgRatingVal);
                        }

                        @{
                            var halfStar = avgRatingVal - fullStars >= 0.3 && avgRatingVal - fullStars <= 0.8;
                        }

                        @{
                            var emptyStars = 5 - fullStars - (halfStar ? 1 : 0);

                            for (var i = 0; i < fullStars; i++)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                     class="bi bi-star-fill me-1" viewBox="0 0 16 16">
                                    <path
                                        d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
                                </svg>
                            }

                            if (halfStar)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                     class="bi bi-star-half me-1" viewBox="0 0 16 16">
                                    <path
                                        d="M5.354 5.119 7.538.792A.516.516 0 0 1 8 .5c.183 0 .366.097.465.292l2.184 4.327 4.898.696A.537.537 0 0 1 16 6.32a.548.548 0 0 1-.17.445l-3.523 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256a.519.519 0 0 1-.146.05c-.341.06-.668-.254-.6-.642l.83-4.73L1.73 6.765a.55.55 0 0 1-.172-.403.59.59 0 0 1 .085-.302.513.513 0 0 1 .37-.245zM8 12.027a.5.5 0 0 1 .232.056l3.686 1.894-.694-3.957a.56.56 0 0 1 .162-.505l2.906-2.77-4.052-.576a.53.53 0 0 1-.393-.288L8 2.223z"/>
                                </svg>
                            }

                            for (var i = 0; i < emptyStars; i++)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor"
                                     class="bi bi-star text-muted opacity-25 me-1" viewBox="0 0 16 16">
                                    <path
                                        d="M2.866 14.85c-.078.444.36.791.746.593l4.39-2.256 4.389 2.256c.386.198.824-.149.746-.592l-.83-4.73 3.522-3.356c.33-.314.16-.888-.282-.95l-4.898-.696L8.465.792a.513.513 0 0 0-.927 0L5.354 5.12l-4.898.696c-.441.062-.612.636-.283.95l3.523 3.356-.83 4.73zm4.905-2.767-3.686 1.894.694-3.957a.565.565 0 0 0-.163-.505L1.71 6.745l4.052-.576a.525.525 0 0 0 .393-.288L8 2.223l1.847 3.658a.525.525 0 0 0 .393.288l4.052.575-2.906 2.77a.565.565 0 0 0-.163.506l.694 3.957-3.686-1.894a.503.503 0 0 0-.461 0z"/>
                                </svg>
                            }
                        }
                    </div>
                    <span class="text-muted small fw-medium">@Model.AverageRating.Value.ToString("0.0")</span>
                }
                else
                {
                    <span class="text-muted small">Chưa có đánh giá</span>
                }
            </div>

            <div class="mt-auto">
                <p class="text-danger fw-bold fs-5 mb-0">
                    @Model.Price.ToString("N0") đ <span
                        class="text-muted fs-6 fw-normal">/ @Model.ProductUnitName</span>
                </p>
            </div>
        </div>
    </a>
</div>
