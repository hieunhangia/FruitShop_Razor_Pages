@model Service.DTOs.Guest.Homepage.ProductDto

<a asp-page="/Guest/ProductDetail" asp-route-id="@Model.Id" class="text-decoration-none">
    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card" style="transition: transform 0.2s, box-shadow 0.2s;">
        <div style="height: 180px; overflow: hidden; background: #f8f9fa;">
            <img src="@Model.ImageUrl"
                 alt="@Model.Name"
                 class="w-100 h-100"
                 style="object-fit: cover;"
            />
        </div>
        <div class="card-body d-flex flex-column p-3">
            <h6 class="card-title fw-bold text-truncate mb-1 text-dark" title="@Model.Name">@Model.Name</h6>
            <p class="text-muted small mb-2 flex-grow-1"
               style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                @Model.Description
            </p>
            <div class="d-flex align-items-center justify-content-between mt-auto">
                <span class="text-success fw-bold fs-6">
                    @Model.Price.ToString("N0") ₫
                    <small class="text-muted fw-normal fs-7">/ @Model.ProductUnitName</small>
                </span>
            </div>
            <div class="mt-2 text-muted small">
                Còn lại: @Model.AvailableQuantity
                @Model.ProductUnitName
            </div>
        </div>
    </div>
</a>

<style>
    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
</style>