@page "{id:int}"
@using Repository.Constants
@using Repository.Models.Coupons
@model FruitShop_Razor_Pages.Pages.Manager.Coupon.DetailModel

@{
    ViewData["Title"] = "Chi tiết mã giảm giá";
}

<div class="container py-5">

    @if (TempData["StatusMessage"] is string statusMessage)
    {
        <div class="alert alert-success rounded-4">@statusMessage</div>
    }

    <div class="row g-4">
        <div class="col-lg-12">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body">
                    <h5 class="card-title fw-semibold">Cập nhật mã giảm giá</h5>
                    <form method="post" class="mt-3">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Input.Description" class="form-label fw-medium"></label>
                            <input asp-for="Input.Description" class="form-control" />
                            <span asp-validation-for="Input.Description" class="text-danger"></span>
                        </div>

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Input.DiscountType" class="form-label fw-medium"></label>
                                <select asp-for="Input.DiscountType" class="form-select">
                                    <option value="@DiscountType.Percentage">Phần trăm</option>
                                    <option value="@DiscountType.FixedAmount">Số tiền</option>
                                </select>
                                <span asp-validation-for="Input.DiscountType" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.DiscountValue" class="form-label fw-medium"></label>
                                <input asp-for="Input.DiscountValue" class="form-control" type="number" min="0" />
                                <span asp-validation-for="Input.DiscountValue" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Input.MaxDiscountAmount" class="form-label fw-medium"></label>
                                <input asp-for="Input.MaxDiscountAmount" class="form-control" type="number" min="0" />
                                <span asp-validation-for="Input.MaxDiscountAmount" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Input.MinOrderAmount" class="form-label fw-medium"></label>
                                <input asp-for="Input.MinOrderAmount" class="form-control" type="number" min="0" />
                                <span asp-validation-for="Input.MinOrderAmount" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                <label asp-for="Input.LoyaltyPointsCost" class="form-label fw-medium"></label>
                                <input asp-for="Input.LoyaltyPointsCost" class="form-control" type="number" min="0" />
                                <span asp-validation-for="Input.LoyaltyPointsCost" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="form-check">
                                    <input asp-for="Input.IsActive" class="form-check-input" />
                                    <label asp-for="Input.IsActive" class="form-check-label">Đang áp dụng</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end mt-4">
                            <button type="submit" class="btn btn-success">Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


