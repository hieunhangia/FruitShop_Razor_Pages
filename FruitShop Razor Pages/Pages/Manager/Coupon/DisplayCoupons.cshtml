@page
@using Repository.Constants
@using Repository.Models.Coupons
@model IndexModel

@{
    ViewData["Title"] = "Danh sách mã giảm giá";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success mb-0">Danh sách mã giảm giá</h2>
    </div>
    <form method="get">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center text-dark">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                         class="me-2 text-success" viewBox="0 0 16 16">
                        <path
                            d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2h-11z"/>
                    </svg>
                    Bộ lọc tìm kiếm
                </h5>
                <div asp-validation-summary="All" class="text-danger mb-3 small fw-medium" role="alert"></div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Từ khóa</label>
                        <input asp-for="PagedAndSortedRequest.Filter.Keyword" class="form-control rounded-3"
                               placeholder="Mô tả hoặc mã..."/>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Loại giảm giá</label>
                        <select asp-for="PagedAndSortedRequest.Filter.DiscountType" class="form-select rounded-3">
                            <option value="">Tất cả loại</option>
                            <option value="@DiscountType.Percentage">Phần trăm</option>
                            <option value="@DiscountType.FixedAmount">Số tiền</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Trạng thái</label>
                        <select asp-for="PagedAndSortedRequest.Filter.IsActive" class="form-select rounded-3">
                            <option value="">Tất cả trạng thái</option>
                            <option value="true">Đang áp dụng</option>
                            <option value="false">Ngừng áp dụng</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Sắp xếp theo</label>
                        <select asp-for="PagedAndSortedRequest.SortColumn" class="form-select rounded-3">
                            <option value="@nameof(Coupon.DiscountValue)">Giá trị</option>
                            <option value="@nameof(Coupon.MaxDiscountAmount)">Giảm tối đa</option>
                            <option value="@nameof(Coupon.MinOrderAmount)">Đơn tối thiểu</option>
                            <option value="@nameof(Coupon.LoyaltyPointsCost)">Điểm đổi</option>
                            <option value="@nameof(Coupon.IsActive)">Trạng thái</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Thứ tự</label>
                        <select asp-for="PagedAndSortedRequest.SortDirection" class="form-select rounded-3">
                            <option value="@SortDirection.Ascending">Tăng dần</option>
                            <option value="@SortDirection.Descending">Giảm dần</option>
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button type="submit" name="isSearch" value="true"
                                class="btn btn-success rounded-3 w-100 fw-medium shadow-sm btn-fruit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                 class="me-1 mb-1" viewBox="0 0 16 16">
                                <path
                                    d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                            </svg>
                            Tìm kiếm & Lọc
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Mô tả</th>
                        <th class="py-3">Loại</th>
                        <th class="py-3 text-end">Giá trị</th>
                        <th class="py-3 text-end">Giảm tối đa</th>
                        <th class="py-3 text-end">Đơn tối thiểu</th>
                        <th class="py-3 text-end">Điểm đổi</th>
                        <th class="text-center py-3">Trạng thái</th>
                        <th class="text-center pe-4 py-3">Thao tác</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (Model.PagedAndSortedResult?.Items.Any() ?? false)
                    {
                        @foreach (var coupon in Model.PagedAndSortedResult.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-medium text-dark">@coupon.Description</td>
                                <td>
                                    @switch (coupon.DiscountType)
                                    {
                                        case DiscountType.Percentage:
                                            <span class="badge bg-info text-dark rounded-pill fw-medium">Phần trăm</span>
                                            break;
                                        case DiscountType.FixedAmount:
                                            <span class="badge bg-primary rounded-pill fw-medium">Số tiền</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary rounded-pill fw-medium">Không xác định</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end fw-bold text-success">@FormatDiscountValue(coupon)</td>
                                <td class="text-end">@FormatCurrency(coupon.MaxDiscountAmount)</td>
                                <td class="text-end">@FormatCurrency(coupon.MinOrderAmount)</td>
                                <td class="text-end">@coupon.LoyaltyPointsCost.ToString("N0")</td>
                                <td class="text-center">
                                    @if (coupon.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill fw-medium">Đang áp dụng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill fw-medium">Ngừng áp dụng</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <a class="btn btn-sm btn-outline-primary" asp-page="/Manager/Coupon/UpdateCoupon" asp-route-id="@coupon.Id">Update</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                                     class="mb-3 opacity-50" viewBox="0 0 16 16">
                                    <path
                                        d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1zm3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4h-3.5zM2 5h12v9a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5z"/>
                                </svg>
                                <br/>
                                Chưa có mã giảm giá nào.
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.PagedAndSortedResult?.TotalPages > 1)
        {
            <div
                class="d-flex flex-column flex-md-row justify-content-between align-items-center bg-white p-3 rounded-4 shadow-sm border border-light">
                <div class="mb-3 mb-md-0 text-muted small">
                    Hiển thị trang <span class="fw-bold text-dark">@Model.PagedAndSortedResult.PageIndex</span> trên
                    <span class="fw-bold text-dark">@Model.PagedAndSortedResult.TotalPages</span>
                </div>

                <div class="d-flex gap-3 align-items-center">
                    <div class="btn-group shadow-sm">
                        @if (Model.PagedAndSortedResult.HasPreviousPage)
                        {
                            <button type="submit" name="PagedAndSortedRequest.PageIndex"
                                    value="@(Model.PagedAndSortedResult.PageIndex - 1)"
                                    class="btn btn-outline-success fw-medium">
                                &laquo; Trước
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-success disabled fw-medium">&laquo; Trước</button>
                        }

                        @if (Model.PagedAndSortedResult.HasNextPage)
                        {
                            <button type="submit" name="PagedAndSortedRequest.PageIndex"
                                    value="@(Model.PagedAndSortedResult.PageIndex + 1)"
                                    class="btn btn-outline-success fw-medium">
                                Sau &raquo;
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-success disabled fw-medium">Sau &raquo;</button>
                        }
                    </div>

                    <div class="d-flex align-items-center border-start ps-3">
                        <span class="text-muted small me-2 text-nowrap">Đến trang:</span>
                        <div class="input-group input-group-sm" style="width: 120px;">
                            <input asp-for="PagedAndSortedRequest.PageIndex"
                                   class="form-control text-center border-success" min="1"
                                   max="@Model.PagedAndSortedResult.TotalPages"
                                   value="@Model.PagedAndSortedResult.PageIndex"/>
                            <button type="submit" class="btn btn-success fw-medium">Đi</button>
                        </div>
                    </div>
                </div>
            </div>
            <span asp-validation-for="PagedAndSortedRequest.PageIndex"
                  class="text-danger small d-block mt-2 text-end"></span>
        }
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}

@functions {
    private static string FormatDiscountValue(Coupon coupon)
    {
        return coupon.DiscountType == DiscountType.Percentage
            ? $"{coupon.DiscountValue}%"
            : FormatCurrency(coupon.DiscountValue);
    }

    private static string FormatCurrency(long? amount)
    {
        return amount.HasValue ? $"{amount.Value:N0} đ" : "—";
    }
}
