@page
@model FruitShop_Razor_Pages.Pages.SalesStaff.Category.CategoryCreateModel
@{
    ViewData["Title"] = "Thêm danh mục mới";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="fw-bold">Thêm danh mục mới</h2>
                <a asp-page="./CategoryManagement" class="btn btn-outline-secondary rounded-pill">Quay lại</a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Tên danh mục</label>
                            <input asp-for="Category.Name" class="form-control form-control-lg" placeholder="Ví dụ: Trái cây nhập khẩu" required />
                        </div>

                        <div class="text-center">
                            <button type="submit" class="btn btn-primary w-100 py-2 rounded-pill fw-bold">Xác nhận tạo danh mục</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>