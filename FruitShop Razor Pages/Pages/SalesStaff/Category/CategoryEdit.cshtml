@page "{id:int}"
@model FruitShop_Razor_Pages.Pages.SalesStaff.Category.CategoryEditModel
@{
    ViewData["Title"] = "Cập nhật danh mục";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Cập nhật danh mục</h2>
            <p class="text-muted small mb-0">ID Danh mục: #@Model.CategoryId</p>
        </div>
        <div>
            <button type="submit" form="categoryEditForm" class="btn btn-primary rounded-pill px-4 me-2 fw-bold shadow-sm">
                Lưu cập nhật
            </button>
            <a asp-page="./CategoryManagement" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm">
                Hủy & Quay lại
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-4">
            <form id="categoryEditForm" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-muted small">Tên danh mục</label>
                            <input asp-for="CategoryUpdate.Name" class="form-control form-control-lg" 
                                   placeholder="Nhập tên danh mục (vd: Trái cây nhập khẩu)" required />
                            <span asp-validation-for="CategoryUpdate.Name" class="text-danger small"></span>
                        </div>
                        
                    </div>

                    <div class="col-md-4 border-start ps-4">
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small d-block">Trạng thái hoạt động</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" role="switch" 
                                       id="statusSwitch" asp-for="CategoryUpdate.IsActive" style="transform: scale(1.3);">
                                <label class="form-check-label ms-2 fw-medium" for="statusSwitch">
                                    @(Model.CategoryUpdate.IsActive ? "Đang kinh doanh" : "Đang ngừng kinh doanh")
                                </label>
                            </div>
                        </div>

                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hiệu ứng thay đổi text label ngay lập tức khi gạt switch trạng thái
        document.getElementById('statusSwitch').addEventListener('change', function() {
            const label = this.nextElementSibling;
            label.textContent = this.checked ? "Đang kinh doanh" : "Đang ngừng kinh doanh";
        });
    </script>
}