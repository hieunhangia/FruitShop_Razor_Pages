@page
@using Repository.Constants
@model FruitShop_Razor_Pages.Pages.SalesStaff.Category.CategoryManagementModel
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Danh mục sản phẩm</h2>
        <div>
            <a asp-page="./CategoryPriorityManagement" class="btn btn-outline-primary rounded-pill px-4 me-2 fw-bold">Quản lý ưu tiên</a>
            <a asp-page="./CategoryCreate" class="btn btn-primary rounded-pill px-4 fw-bold">Thêm mới</a>
        </div>
    </div>

    <form id="filterForm" method="get" class="card shadow-sm border-0 mb-4">
        <input type="hidden" asp-for="RequestData.PageIndex" id="pageIndexInput" />
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Tên danh mục</label>
                    <input type="text" asp-for="RequestData.Filter.SearchName" class="form-control" placeholder="Tìm kiếm...">
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Trạng thái</label>
                    <select asp-for="RequestData.Filter.IsActive" class="form-select">
                        <option value="">Tất cả</option>
                        <option value="true">Hoạt động</option>
                        <option value="false">Khóa</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Sắp xếp theo</label>
                    <select asp-for="RequestData.SortColumn" class="form-select">
                        <option value="Id">Mặc định (ID)</option>
                        <option value="Name">Tên danh mục</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Thứ tự</label>
                    <div class="d-flex gap-2">
                        <select asp-for="RequestData.SortDirection" class="form-select">
                            <option value="@SortDirection.Ascending">Tăng dần</option>
                            <option value="@SortDirection.Descending">Giảm dần</option>
                        </select>
                        <button type="button" class="btn btn-success fw-bold px-4" onclick="document.getElementById('pageIndexInput').value = 1; document.getElementById('filterForm').submit();">Lọc</button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0 bg-white">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Tên danh mục</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Categories?.Items.Count > 0)
                {
                    foreach (var item in Model.Categories.Items)
                    {
                        <tr>
                            <td class="fw-bold text-muted">#@item.Id</td>
                            <td class="fw-bold">@item.Name</td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")">
                                    @(item.IsActive ? "Hoạt động" : "Khóa")
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-page="./CategoryEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">Sửa</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.Categories?.TotalPages > 1)
    {
        <div class="d-flex justify-content-end align-items-center mt-4">
            <button type="button" class="btn btn-outline-secondary me-3" @(Model.Categories.HasPreviousPage ? "" : "disabled")
                    onclick="document.getElementById('pageIndexInput').value = @(Model.Categories.PageIndex - 1); document.getElementById('filterForm').submit();">
                Trước
            </button>

            <span class="me-2 fw-medium">Trang</span>
            <input type="number" class="form-control text-center px-1" value="@Model.Categories.PageIndex" min="1" max="@Model.Categories.TotalPages" style="width: 65px;"
                   onchange="document.getElementById('pageIndexInput').value = this.value; document.getElementById('filterForm').submit();" />
            <span class="mx-2 fw-medium">/ @Model.Categories.TotalPages</span>

            <button type="button" class="btn btn-outline-secondary ms-3" @(Model.Categories.HasNextPage ? "" : "disabled")
                    onclick="document.getElementById('pageIndexInput').value = @(Model.Categories.PageIndex + 1); document.getElementById('filterForm').submit();">
                Sau
            </button>
        </div>
    }
</div>