@page
@using Repository.Constants
@model FruitShop_Razor_Pages.Pages.SalesStaff.Category.CategoryManagementModel
@{
    ViewData["Title"] = "Quản lý danh mục";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Danh mục sản phẩm</h2>
            <p class="text-muted mb-0 small">Quản lý và phân loại các nhóm sản phẩm</p>
        </div>
        <div>
            <a asp-page="./CategoryPriorityManagement" class="btn btn-outline-primary rounded-pill px-4 me-2 fw-medium shadow-sm">Quản lý ưu tiên</a>
            <a asp-page="./CategoryCreate" class="btn btn-primary rounded-pill px-4 fw-medium shadow-sm">Thêm mới</a>
        </div>
    </div>

    <form method="get" id="filterForm">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center text-dark">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2 text-primary" viewBox="0 0 16 16">
                        <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2h-11z" />
                    </svg>
                    Bộ lọc & sắp xếp
                </h5>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label small fw-medium text-muted mb-1">Tên danh mục</label>
                        <input type="text" asp-for="RequestData.Filter.SearchName" class="form-control rounded-3" placeholder="Nhập từ khóa...">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-medium text-muted mb-1">Trạng thái</label>
                        <select asp-for="RequestData.Filter.IsActive" class="form-select rounded-3">
                            <option value="">Tất cả</option>
                            <option value="true">Đang hoạt động</option>
                            <option value="false">Đang khóa</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-medium text-muted mb-1">Sắp xếp theo</label>
                        <select asp-for="RequestData.SortColumn" class="form-select rounded-3">
                            <option value="DisplayOrder">Ưu tiên</option>
                            <option value="Id">ID</option>
                            <option value="Name">Tên</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small fw-medium text-muted mb-1">Thứ tự</label>
                        <select asp-for="RequestData.SortDirection" class="form-select rounded-3">
                            <option value="@SortDirection.Ascending">Tăng dần</option>
                            <option value="@SortDirection.Descending">Giảm dần</option>
                        </select>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" name="RequestData.PageIndex" value="1" class="btn btn-primary rounded-3 w-100 fw-medium shadow-sm">Áp dụng</button>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Mã DM</th>
                        <th class="py-3">Tên danh mục</th>
                        <th class="py-3">Trạng thái</th>
                        <th class="text-center pe-4 py-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Categories?.Items.Count > 0)
                    {
                        foreach (var item in Model.Categories.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-muted">#@item.Id</td>
                                <td class="fw-bold text-dark">@item.Name</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill fw-medium">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-pill fw-medium">Đang khóa</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="d-flex justify-content-center gap-2">
                                        <a asp-page="./CategoryEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-medium">Sửa</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">Không tìm thấy danh mục nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Categories?.TotalPages > 1)
    {
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center bg-white p-3 rounded-4 shadow-sm border border-light">
            <div class="mb-3 mb-md-0 text-muted small">
                Hiển thị trang <span class="fw-bold text-dark">@Model.Categories.PageIndex</span> trên
                <span class="fw-bold text-dark">@Model.Categories.TotalPages</span>
            </div>
            <div class="d-flex gap-3 align-items-center">
                <div class="btn-group shadow-sm">
                    <button type="submit" form="filterForm" name="RequestData.PageIndex" value="@(Model.Categories.PageIndex - 1)" class="btn btn-outline-primary fw-medium @(!Model.Categories.HasPreviousPage ? "disabled" : "")">&laquo; Trước</button>
                    <button type="submit" form="filterForm" name="RequestData.PageIndex" value="@(Model.Categories.PageIndex + 1)" class="btn btn-outline-primary fw-medium @(!Model.Categories.HasNextPage ? "disabled" : "")">Sau &raquo;</button>
                </div>
                <div class="d-flex align-items-center border-start ps-3">
                    <span class="text-muted small me-2 text-nowrap">Đến trang:</span>
                    <div class="input-group input-group-sm" style="width: 120px;">
                        <input name="RequestData.PageIndex" form="filterForm" class="form-control text-center border-primary" min="1" max="@Model.Categories.TotalPages" value="@Model.Categories.PageIndex" />
                        <button type="submit" form="filterForm" class="btn btn-primary fw-medium">Đi</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>