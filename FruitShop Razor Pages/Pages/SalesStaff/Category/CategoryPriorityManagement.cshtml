@page
@model FruitShop_Razor_Pages.Pages.SalesStaff.Category.CategoryPriorityManagementModel
@{
    ViewData["Title"] = "Thứ tự ưu tiên danh mục";
}
@Html.AntiForgeryToken()
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Thứ tự ưu tiên danh mục</h2>
            <p class="text-muted mb-0">Kéo thả để thay đổi vị trí hiển thị danh mục.</p>
        </div>
        <div>
            <button type="button" class="btn btn-primary rounded-pill px-4 me-2 fw-bold" onclick="savePriority()">Cập nhật thứ tự</button>
            <a asp-page="./CategoryManagement" class="btn btn-outline-secondary rounded-pill px-4 fw-bold">Quay lại</a>
        </div>
    </div>
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-0">
            <div class="list-group list-group-flush" id="sortableCategoryList">
                @{
                    int index = 1;
                }
                @foreach (var c in Model.Categories)
                {
                    <div class="list-group-item d-flex align-items-center py-3 px-4 border-bottom" data-id="@c.Id" style="cursor: grab;">
                        <span class="fs-5 fw-bold text-primary me-3 text-center" style="width: 35px;">@(index++)</span>
                        <span class="fs-4 text-muted me-4">&#8942;&#8942;</span>
                        <div class="flex-grow-1 text-truncate">
                            <span class="fw-bold fs-5">@c.Name</span>
                            @if (!c.IsActive)
                            {
                                <span class="badge bg-danger ms-3">Đã khóa</span>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        var el = document.getElementById('sortableCategoryList');
        Sortable.create(el, {
            animation: 150,
            ghostClass: 'bg-light-styled'
        });
    });
    function savePriority() {
        var ids = [];
        document.querySelectorAll('#sortableCategoryList .list-group-item').forEach(item => {
            ids.push(parseInt(item.getAttribute('data-id')));
        });
        var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        fetch('?handler=UpdatePriority', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify(ids)
        })
        .then(() => {
            location.reload();
        });
    }
</script>
<style>
    .bg-light-styled {
        background-color: #f8f9fa !important;
        border: 2px dashed #007bff !important;
    }

    .list-group-item:active {
        cursor: grabbing !important;
        background-color: #f1f3f5;
    }
</style>