@page
@model FruitShop_Razor_Pages.Pages.SalesStaff.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}
<div class="container py-4">
    <h2 class="mb-4 fw-bold">Tổng quan hệ thống</h2>
    <div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 bg-primary text-white h-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title">Sản phẩm</h5>
                    <h2 class="display-6 fw-bold">@Model.Stats.TotalProducts</h2>
                </div>
                <a asp-page="/SalesStaff/Product/ProductManagement" class="btn btn-light rounded-pill px-4 align-self-start fw-bold mt-3">Quản lý Sản phẩm</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 bg-success text-white h-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title">Danh mục</h5>
                    <h2 class="display-6 fw-bold">@Model.Stats.TotalCategories</h2>
                </div>
                <a asp-page="/SalesStaff/Category/CategoryManagement" class="btn btn-light rounded-pill px-4 align-self-start fw-bold mt-3">Quản lý Danh mục</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 bg-warning text-dark h-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title">Đơn vị tính</h5>
                    <p class="mb-0">Quản lý cấu hình đơn vị đo lường</p>
                </div>
                <a asp-page="/SalesStaff/ProductUnit/ProductUnitManagement" class="btn btn-dark rounded-pill px-4 align-self-start fw-bold mt-3">Quản lý Đơn vị</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 bg-primary text-white h-100">
            <div class="card-body d-flex flex-column justify-content-between">
                <div>
                    <h5 class="card-title">Order</h5>
                    @* <h2 class="display-6 fw-bold">@Model.Stats.TotalProducts</h2> *@
                </div>
                <a asp-page="/SalesStaff/Order/View" class="btn btn-light rounded-pill px-4 align-self-start fw-bold mt-3">Quản lý Sản phẩm</a>
            </div>
        </div>
    </div>
</div>
</div>