@page
@model FruitShop_Razor_Pages.Pages.SalesStaff.Dashboard.IndexModel
@{
    ViewData["Title"] = "Bảng điều khiển Nhân viên Bán hàng";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1 d-flex align-items-center">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" class="me-2 text-primary" viewBox="0 0 16 16">
                    <path d="M8 4a.5.5 0 0 1 .5.5V6a.5.5 0 0 1-1 0V4.5A.5.5 0 0 1 8 4M3.732 5.732a.5.5 0 0 1 .707 0l.915.914a.5.5 0 1 1-.708.708l-.914-.915a.5.5 0 0 1 0-.707zM2 10a.5.5 0 0 1 .5-.5h1.586a.5.5 0 0 1 0 1H2.5A.5.5 0 0 1 2 10zm9.5 0a.5.5 0 0 1 .5-.5h1.5a.5.5 0 0 1 0 1H12a.5.5 0 0 1-.5-.5zm.754-4.246a.389.389 0 0 0-.527-.02L7.547 9.31a.91.91 0 1 0 1.302 1.258l3.434-4.297a.389.389 0 0 0-.029-.518z" />
                    <path fill-rule="evenodd" d="M0 10a8 8 0 1 1 15.547 2.661c-.442 1.253-1.845 2.502-3.149 2.815A2.99 2.99 0 0 1 10.45 16H5.549a2.99 2.99 0 0 1-1.948-.524C2.302 15.163.899 13.914.453 12.661A8 8 0 0 1 0 10m8-7a7 7 0 0 0-6.603 9.329c.203.575.923 1.752 2.128 2.087A1.99 1.99 0 0 0 5.55 15h4.9a1.99 1.99 0 0 0 2.023-.684c1.205-.335 1.925-1.512 2.128-2.087A7 7 0 0 0 8 3" />
                </svg>
                Bảng điều khiển Sales
            </h2>
            <p class="text-muted mb-0">Quản lý tổng quan về sản phẩm, danh mục và đơn hàng</p>
        </div>
        <button onclick="location.reload()" class="btn btn-outline-primary rounded-pill px-4 fw-medium shadow-sm">
            <i class="bi bi-arrow-clockwise me-2"></i>Làm mới dữ liệu
        </button>
    </div>

    <div class="row g-4 mb-4">
        <!-- Sản phẩm -->
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 rounded-4 shadow-sm bg-primary bg-opacity-10 border-start border-5 border-primary h-100 hover-lift">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center mb-3">
                            <div class="text-primary me-3">
                                <i class="bi bi-box-seam fs-1"></i>
                            </div>
                            <h5 class="fw-bold text-dark mb-0">Sản phẩm</h5>
                        </div>
                        <h2 class="display-6 fw-bold text-primary mb-1">@Model.Stats.TotalProducts</h2>
                        <p class="text-muted small fw-medium mb-0"><span class="text-success">@Model.Stats.ActiveProducts đang bán</span></p>
                    </div>
                    <a asp-page="/SalesStaff/Product/ProductManagement" class="btn btn-primary rounded-pill mt-4 fw-medium w-100 shadow-sm d-flex align-items-center justify-content-center">
                        Quản lý Sản phẩm
                        <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Danh mục -->
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 rounded-4 shadow-sm bg-success bg-opacity-10 border-start border-5 border-success h-100 hover-lift">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center mb-3">
                            <div class="text-success me-3">
                                <i class="bi bi-tags fs-1"></i>
                            </div>
                            <h5 class="fw-bold text-dark mb-0">Danh mục</h5>
                        </div>
                        <h2 class="display-6 fw-bold text-success mb-1">@Model.Stats.TotalCategories</h2>
                        <p class="text-muted small fw-medium mb-0"><span class="text-success">@Model.Stats.ActiveCategories đang hoạt động</span></p>
                    </div>
                    <a asp-page="/SalesStaff/Category/CategoryManagement" class="btn btn-success rounded-pill mt-4 fw-medium w-100 shadow-sm d-flex align-items-center justify-content-center">
                        Quản lý Danh mục
                        <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Đơn vị tính -->
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 rounded-4 shadow-sm bg-warning bg-opacity-10 border-start border-5 border-warning h-100 hover-lift">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center mb-3">
                            <div class="text-warning me-3">
                                <i class="bi bi-rulers fs-1"></i>
                            </div>
                            <h5 class="fw-bold text-dark mb-0">Đơn vị tính</h5>
                        </div>
                        <h2 class="display-6 fw-bold text-warning mb-1">--</h2>
                        <p class="text-muted small fw-medium mb-0">Thiết lập cấu hình đo lường</p>
                    </div>
                    <a asp-page="/SalesStaff/ProductUnit/ProductUnitManagement" class="btn btn-warning text-dark rounded-pill mt-4 fw-medium w-100 shadow-sm d-flex align-items-center justify-content-center">
                        Quản lý Đơn vị
                        <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Order -->
        <div class="col-lg-3 col-md-6">
            <div class="card border-0 rounded-4 shadow-sm bg-info bg-opacity-10 border-start border-5 border-info h-100 hover-lift">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div>
                        <div class="d-flex align-items-center mb-3">
                            <div class="text-info me-3">
                                <i class="bi bi-cart-check fs-1"></i>
                            </div>
                            <h5 class="fw-bold text-dark mb-0">Đơn hàng</h5>
                        </div>
                        <h2 class="display-6 fw-bold text-info mb-1">--</h2>
                        <p class="text-muted small fw-medium mb-0">Xử lý các đơn hàng</p>
                    </div>
                    <a asp-page="/SalesStaff/Order/View" class="btn btn-info text-dark rounded-pill mt-4 fw-medium w-100 shadow-sm d-flex align-items-center justify-content-center">
                        Quản lý Đơn hàng
                        <i class="bi bi-arrow-right ms-2"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .15) !important;
    }
</style>