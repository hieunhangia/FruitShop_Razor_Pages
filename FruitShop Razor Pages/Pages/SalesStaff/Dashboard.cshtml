@page
@model FruitShop_Razor_Pages.Pages.SalesStaff.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container py-4">
    <h2 class="mb-4 fw-bold">Tổng quan hệ thống</h2>
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card shadow-sm border-0 bg-primary text-white h-100">
                <div class="card-body">
                    <h5 class="card-title">Quản lý Sản phẩm</h5>
                    <h2 class="display-6 fw-bold">@Model.Stats.TotalProducts</h2>
                    <p class="mb-3">Đang hoạt động: @Model.Stats.ActiveProducts</p>
                    <a asp-page="/SalesStaff/Product/ProductManagement" class="btn btn-light rounded-pill px-4">Truy cập ngay</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm border-0 bg-success text-white h-100">
                <div class="card-body">
                    <h5 class="card-title">Quản lý Danh mục</h5>
                    <h2 class="display-6 fw-bold">@Model.Stats.TotalCategories</h2>
                    <p class="mb-3">Đang hoạt động: @Model.Stats.ActiveCategories</p>
                    <a asp-page="/SalesStaff/Category/CategoryManagement" class="btn btn-light rounded-pill px-4">Truy cập ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>