@page
@using Repository.Constants
@using Repository.Models.Orders
@model FruitShop_Razor_Pages.Pages.SalesStaff.Order.View

@{
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Quản lý đơn hàng</h2>
            <p class="text-muted mb-0 small">Danh sách tất cả đơn hàng trong hệ thống</p>
        </div>
    </div>

    <form method="get">
        <!-- Bộ lọc & sắp xếp -->
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center text-dark">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor"
                         class="me-2 text-primary" viewBox="0 0 16 16">
                        <path
                            d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2h-11z"/>
                    </svg>
                    Bộ lọc & sắp xếp
                </h5>
                <div asp-validation-summary="All" class="text-danger mb-3 small fw-medium" role="alert"></div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Từ ngày</label>
                        <input type="date" asp-for="PagedAndSortedRequest.Filter.StartDate"
                               class="form-control rounded-3"/>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Đến ngày</label>
                        <input type="date" asp-for="PagedAndSortedRequest.Filter.EndDate"
                               class="form-control rounded-3"/>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Sắp xếp theo</label>
                        <select asp-for="PagedAndSortedRequest.SortColumn" class="form-select rounded-3">
                            <option value="@nameof(Order.OrderDate)">Ngày đặt hàng</option>
                            <option value="@nameof(Order.Id)">Mã đơn hàng</option>
                            <option value="@nameof(Order.TotalAmount)">Tổng tiền</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Thanh toán</label>
                        <select asp-for="PagedAndSortedRequest.Filter.PaymentMethod" class="form-select rounded-3">
                            <option value="">Tất cả</option>
                            <option value="@PaymentMethod.CashOnDelivery">COD</option>
                            <option value="@PaymentMethod.QRCode">QR</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Thứ tự</label>
                        <select asp-for="PagedAndSortedRequest.SortDirection" class="form-select rounded-3">
                            <option value="@SortDirection.Descending">Giảm dần</option>
                            <option value="@SortDirection.Ascending">Tăng dần</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Trạng thái</label>
                        <select asp-for="PagedAndSortedRequest.Filter.OrderStatus" class="form-select rounded-3">
                            <option value="">Tất cả</option>
                            <option value="@OrderStatus.PendingConfirmation">Chờ xác nhận</option>
                            <option value="@OrderStatus.PendingPayment">Chờ thanh toán</option>
                            <option value="@OrderStatus.Processing">Đang xử lý</option>
                            <option value="@OrderStatus.Shipping">Đang giao</option>
                            <option value="@OrderStatus.Delivered">Đã giao</option>
                            <option value="@OrderStatus.Cancelled">Đã huỷ</option>
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end gap-2">
                        <button type="submit" name="isSearch" value="true"
                                class="btn btn-primary rounded-3 w-100 fw-medium shadow-sm">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor"
                                 class="me-1 mb-1" viewBox="0 0 16 16">
                                <path
                                    d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001c.03.04.062.078.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1.007 1.007 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0z"/>
                            </svg>
                            Áp dụng
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bảng danh sách đơn hàng -->
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Mã đơn</th>
                        <th class="py-3">Ngày đặt</th>
                        <th class="py-3">Trạng thái</th>
                        <th class="py-3">Thanh toán</th>
                        <th class="py-3 text-end">Tổng tiền</th>
                        <th class="py-3">Email khách hàng</th>
                        <th class="py-3">Shipper</th>
                        <th class="text-center pe-4 py-3">Thao tác</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (Model.PagedAndSortedResult?.Items.Any() ?? false)
                    {
                        @foreach (var order in Model.PagedAndSortedResult.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">#@order.Id</td>
                                <td>@order.OrderDate.ToString("HH:mm dd/MM/yyyy")</td>
                                <td>
                                    @switch (order.OrderStatus)
                                    {
                                        case "Chờ xác nhận":
                                            <span class="badge bg-warning text-dark rounded-pill fw-medium">Chờ xác nhận</span>
                                            break;
                                        case "Chờ thanh toán":
                                            <span class="badge bg-info text-dark rounded-pill fw-medium">Chờ thanh toán</span>
                                            break;
                                        case "Đang xử lý":
                                            <span class="badge bg-primary rounded-pill fw-medium">Đang xử lý</span>
                                            break;
                                        case "Đang giao":
                                            <span class="badge bg-info rounded-pill fw-medium">Đang giao</span>
                                            break;
                                        case "Đã giao":
                                            <span class="badge bg-success rounded-pill fw-medium">Đã giao</span>
                                            break;
                                        case "Đã huỷ":
                                            <span class="badge bg-danger rounded-pill fw-medium">Đã huỷ</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary rounded-pill fw-medium">@order.OrderStatus</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @switch (order.PaymentMethod)
                                    {
                                        case PaymentMethod.CashOnDelivery:
                                            <span class="text-dark fw-medium d-flex align-items-center">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                     fill="currentColor" class="me-2 text-success" viewBox="0 0 16 16">
                                                    <path
                                                        d="M1 3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1H1zm7 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/>
                                                    <path
                                                        d="M0 5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V5zm3 0a2 2 0 0 1-2 2v4a2 2 0 0 1 2 2h10a2 2 0 0 1 2-2V7a2 2 0 0 1-2-2H3z"/>
                                                </svg>
                                                COD
                                            </span>
                                            break;
                                        case PaymentMethod.QRCode:
                                            <span class="text-dark fw-medium d-flex align-items-center">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                     fill="currentColor" class="me-2 text-primary" viewBox="0 0 16 16">
                                                    <path d="M2 2h2v2H2V2Z"/>
                                                    <path d="M6 0v6H0V0h6ZM5 1H1v4h4V1ZM4 12H2v2h2v-2Z"/>
                                                    <path d="M6 10v6H0v-6h6Zm-5 1v4h4v-4H1Zm11-9h2v2h-2V2Z"/>
                                                    <path
                                                        d="M10 0v6h6V0h-6Zm5 1v4h-4V1h4ZM8 1V0h1v2H8v2H7V1h1Zm0 5V4h1v2H8ZM6 8V7h1V6h1v2h1V7h5v1h-4v1H7V8H6Zm0 0v1H2V8H1v1H0V7h3v1h3Zm10 1h-1V7h1v2Zm-1 0h-1v2h2v-1h-1V9Zm-4 0h2v1h-1v1h-1V9Zm2 3v-1h-1v1h-1v1H9v1h3v-2h1Zm0 0h3v1h-2v1h-1v-2Zm-4-1v1h1v-2H7v1h2Z"/>
                                                    <path d="M7 12h1v3h4v1H7v-4Zm9 2v2h-3v-1h2v-1h1Z"/>
                                                </svg>
                                                QR
                                            </span>
                                            break;
                                        default:
                                            <span>Không xác định</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end fw-bold text-success">@order.TotalAmount.ToString("N0") đ</td>
                                <td class="text-muted">@order.CustomerEmail</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(order.ShipperName))
                                    {
                                        <span class="fw-medium">@order.ShipperName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Chưa gán</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <a asp-page="Detail" asp-route-id="@order.Id"
                                       class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-medium">Chi tiết</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor"
                                     class="mb-3 opacity-50" viewBox="0 0 16 16">
                                    <path
                                        d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1zm3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4h-3.5zM2 5h12v9a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5z"/>
                                </svg>
                                <br/>
                                Không có đơn hàng nào.
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Phân trang -->
        @if (Model.PagedAndSortedResult?.TotalPages > 1)
        {
            <div
                class="d-flex flex-column flex-md-row justify-content-between align-items-center bg-white p-3 rounded-4 shadow-sm border border-light">
                <div class="mb-3 mb-md-0 text-muted small">
                    Hiển thị trang <span class="fw-bold text-dark">@Model.PagedAndSortedResult.PageIndex</span> trên
                    <span class="fw-bold text-dark">@Model.PagedAndSortedResult.TotalPages</span>
                    (<span class="fw-bold text-dark">@Model.PagedAndSortedResult.TotalCount</span> đơn hàng)
                </div>

                <div class="d-flex gap-3 align-items-center">
                    <div class="btn-group shadow-sm">
                        @if (Model.PagedAndSortedResult.HasPreviousPage)
                        {
                            <button type="submit" name="PagedAndSortedRequest.PageIndex"
                                    value="@(Model.PagedAndSortedResult.PageIndex - 1)"
                                    class="btn btn-outline-primary fw-medium">
                                &laquo; Trước
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-primary disabled fw-medium">&laquo; Trước
                            </button>
                        }

                        @if (Model.PagedAndSortedResult.HasNextPage)
                        {
                            <button type="submit" name="PagedAndSortedRequest.PageIndex"
                                    value="@(Model.PagedAndSortedResult.PageIndex + 1)"
                                    class="btn btn-outline-primary fw-medium">
                                Sau &raquo;
                            </button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-primary disabled fw-medium">Sau &raquo;
                            </button>
                        }
                    </div>

                    <div class="d-flex align-items-center border-start ps-3">
                        <span class="text-muted small me-2 text-nowrap">Đến trang:</span>
                        <div class="input-group input-group-sm" style="width: 120px;">
                            <input asp-for="PagedAndSortedRequest.PageIndex"
                                   class="form-control text-center border-primary" min="1"
                                   max="@Model.PagedAndSortedResult.TotalPages"
                                   value="@Model.PagedAndSortedResult.PageIndex"/>
                            <button type="submit" class="btn btn-primary fw-medium">Đi</button>
                        </div>
                    </div>
                </div>
            </div>
            <span asp-validation-for="PagedAndSortedRequest.PageIndex"
                  class="text-danger small d-block mt-2 text-end"></span>
        }
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial"/>
}