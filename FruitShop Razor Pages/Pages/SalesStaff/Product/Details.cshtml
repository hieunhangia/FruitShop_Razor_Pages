@page "{id:int}"
@model FruitShop_Razor_Pages.Pages.Products.DetailsModel
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container py-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3 shadow-sm mb-4">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger rounded-3 shadow-sm mb-4">@TempData["ErrorMessage"]</div>
    }

    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="fw-bold text-success border-start border-4 border-success ps-3">👁️ Chi tiết Sản phẩm</h2>
            <a asp-page="/SalesStaff/Dashboard" asp-route-CurrentTab="Product" class="btn btn-outline-secondary rounded-pill px-4">🔙 Quay lại Dashboard</a>
        </div>
    </div>

    @if (Model.Product != null)
    {
        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="row g-0">
                <div class="col-md-4 bg-light d-flex align-items-center justify-content-center p-4">
                    <img src="@(string.IsNullOrEmpty(Model.Product.ImageUrl) ? "https://via.placeholder.com/400" : Model.Product.ImageUrl)"
                         class="img-fluid rounded-3 shadow-sm" alt="@Model.Product.Name" style="max-height: 300px; object-fit: cover;">
                </div>
                <div class="col-md-8">
                    <div class="card-body p-5">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h3 class="card-title fw-bold text-dark mb-0">@Model.Product.Name</h3>
                            <div>
                                @if (Model.Product.IsActive)
                                {
                                    <span class="badge bg-success fs-6">Đang bán</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger fs-6">Ngừng bán</span>
                                }
                            </div>
                        </div>

                        <h4 class="text-success fw-bold mb-4">@Model.Product.Price.ToString("N0") đ / @Model.Product.ProductUnit?.Name</h4>

                        <div class="mb-4">
                            <h6 class="fw-bold text-secondary">Danh mục:</h6>
                            @if (Model.Product.Categories != null && Model.Product.Categories.Any())
                            {
                                @foreach (var cat in Model.Product.Categories)
                                {
                                    <span class="badge bg-info text-dark me-1 fs-6">@cat.Name</span>
                                }
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Chưa phân loại</span>
                            }
                        </div>

                        <div class="row mb-4">
                            <div class="col-6">
                                <h6 class="fw-bold text-secondary">Tồn kho thực tế (Quantity):</h6>
                                <p class="fs-5 mb-0">@Model.Product.Quantity</p>
                            </div>
                            <div class="col-6">
                                <h6 class="fw-bold text-secondary">Đang tạm giữ (Held):</h6>
                                <p class="fs-5 mb-0 text-warning">@Model.Product.HeldQuantity</p>
                            </div>
                        </div>

                        <div class="mb-4">
                            <h6 class="fw-bold text-secondary">Mô tả chi tiết:</h6>
                            <p class="card-text text-muted">@Model.Product.Description</p>
                        </div>

                        <div class="mt-4 pt-3 border-top">
                            <a asp-page="./Edit" asp-route-id="@Model.Product.Id" class="btn btn-warning px-4 me-2 shadow-sm text-dark fw-bold">✏️ Sửa thông tin</a>
                            <a asp-page="./Delete" asp-route-id="@Model.Product.Id" class="btn btn-danger px-4 shadow-sm">🗑️ Xóa</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>