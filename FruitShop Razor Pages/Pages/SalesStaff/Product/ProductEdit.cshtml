@page "{id:int}"
@model FruitShop_Razor_Pages.Pages.SalesStaff.Product.ProductEditModel
@{
	ViewData["Title"] = "Cập nhật sản phẩm";
}
<div class="container py-4">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="fw-bold">Cập nhật sản phẩm</h2>
		<div>
			<button type="submit" form="productEditForm" class="btn btn-primary rounded-pill px-4 me-2 fw-bold">Lưu cập nhật</button>
			<a asp-page="./ProductDetail" asp-route-id="@Model.ProductId" class="btn btn-outline-secondary rounded-pill px-4">Hủy & Quay lại</a>
		</div>
	</div>
	<div class="card shadow-sm border-0">
		<div class="card-body p-4">
			<form id="productEditForm" method="post" enctype="multipart/form-data">
				<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
				<div class="row g-4">
					<div class="col-md-8">
						<div class="mb-3">
							<label class="form-label fw-bold">Tên sản phẩm</label>
							<input asp-for="ProductUpdate.Name" class="form-control" required />
						</div>
						<div class="row mb-3">
							<div class="col-md-6">
								<label class="form-label fw-bold">Giá bán (đ)</label>
								<input asp-for="ProductUpdate.Price" type="number" class="form-control" required />
							</div>
							<div class="col-md-6">
								<label class="form-label fw-bold">Số lượng khả dụng</label>
								<input asp-for="ProductUpdate.Quantity" type="number" class="form-control" required />
							</div>
						</div>
						<div class="mb-3">
							<label class="form-label fw-bold">Mô tả sản phẩm</label>
							<textarea asp-for="ProductUpdate.Description" class="form-control" rows="5" required></textarea>
						</div>
					</div>
					<div class="col-md-4">
						<div class="mb-3 text-center">
							<label class="form-label fw-bold d-block text-start">Hình ảnh hiện tại</label>
							<img src="@Model.CurrentImageUrl" alt="Current Image" class="img-thumbnail mb-2" style="max-height: 150px; object-fit: cover;" />
							<label class="form-label fw-bold d-block text-start mt-2">Chọn ảnh mới (Bỏ trống nếu giữ nguyên)</label>
							<input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
						</div>
						<div class="mb-3">
							<label class="form-label fw-bold">Đơn vị tính</label>
							<select asp-for="ProductUpdate.ProductUnitId" class="form-select" required>
								<option value="">-- Chọn đơn vị --</option>
								@foreach (var unit in Model.ProductUnits)
								{
									<option value="@unit.Id">@unit.Name</option>
								}
							</select>
						</div>
						<div class="mb-3">
							<label class="form-label fw-bold">Danh mục sản phẩm</label>
							<div class="border rounded p-3 bg-light" style="max-height: 200px; overflow-y: auto;">
								@foreach (var cat in Model.Categories)
								{
									bool isChecked = Model.ProductUpdate.CategoryIds.Contains(cat.Id);
									<div class="form-check">
										<input class="form-check-input" type="checkbox" name="ProductUpdate.CategoryIds" value="@cat.Id" id="edit-cat-@cat.Id" @(isChecked ? "checked" : "")>
										<label class="form-check-label" for="edit-cat-@cat.Id">@cat.Name</label>
									</div>
								}
							</div>
						</div>
					</div>
				</div>
			</form>
		</div>
	</div>
</div>  