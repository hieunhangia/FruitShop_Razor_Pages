@page
@using Repository.Constants
@model FruitShop_Razor_Pages.Pages.SalesStaff.Product.ProductManagementModel
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Quản lý sản phẩm</h2>
            <p class="text-muted mb-0 small">Danh sách tất cả sản phẩm trong hệ thống</p>
        </div>
        <div>
            <a asp-page="./PriorityManagement" class="btn btn-outline-primary rounded-pill px-4 me-2 fw-medium shadow-sm">Quản lý ưu tiên</a>
            <a asp-page="./ProductCreate" class="btn btn-primary rounded-pill px-4 fw-medium shadow-sm">Thêm mới</a>
        </div>
    </div>

    <form method="get" id="filterForm">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center text-dark">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2 text-primary" viewBox="0 0 16 16">
                        <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2h-11z" />
                    </svg>
                    Bộ lọc & sắp xếp
                </h5>
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label small fw-medium text-muted mb-1">Tên sản phẩm</label>
                        <input type="text" asp-for="RequestData.Filter.SearchName" class="form-control rounded-3" placeholder="Nhập từ khóa...">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-medium text-muted mb-1">Trạng thái</label>
                        <select asp-for="RequestData.Filter.IsActive" class="form-select rounded-3">
                            <option value="">Tất cả</option>
                            <option value="true">Đang hoạt động</option>
                            <option value="false">Ngừng kinh doanh</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-medium text-muted mb-1">Đơn vị tính</label>
                        <select asp-for="RequestData.Filter.ProductUnitId" class="form-select rounded-3">
                            <option value="">Tất cả</option>
                            @foreach (var unit in Model.ProductUnits)
                            {
                                <option value="@unit.Id">@unit.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-medium text-muted mb-1">Sắp xếp theo</label>
                        <select asp-for="RequestData.SortColumn" class="form-select rounded-3">
                            <option value="DisplayOrder">Mặc định</option>
                            <option value="Name">Tên sản phẩm</option>
                            <option value="Price">Giá bán</option>
                            <option value="Quantity">Tồn kho</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label small fw-medium text-muted mb-1">Giá từ (đ)</label>
                        <input type="number" asp-for="RequestData.Filter.PriceFrom" class="form-control rounded-3" placeholder="0">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-medium text-muted mb-1">Giá đến (đ)</label>
                        <input type="number" asp-for="RequestData.Filter.PriceTo" class="form-control rounded-3" placeholder="Tối đa">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-medium text-muted mb-1">Thứ tự</label>
                        <select asp-for="RequestData.SortDirection" class="form-select rounded-3">
                            <option value="@SortDirection.Ascending">Tăng dần</option>
                            <option value="@SortDirection.Descending">Giảm dần</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" name="RequestData.PageIndex" value="1" class="btn btn-primary rounded-3 w-100 fw-medium shadow-sm">
                            Áp dụng
                        </button>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label small fw-medium text-muted mb-1">Danh mục (Có thể chọn nhiều)</label>
                        <div class="border rounded-3 p-2 bg-white form-control d-flex flex-wrap gap-3 overflow-auto" style="max-height: 100px;">
                            @foreach (var cat in Model.Categories)
                            {
                                bool isChecked = Model.RequestData.Filter.CategoryIds.Contains(cat.Id);
                                <div class="form-check mb-0">
                                    <input class="form-check-input" type="checkbox" name="RequestData.Filter.CategoryIds" value="@cat.Id" id="cat_@cat.Id" @(isChecked ? "checked" : "")>
                                    <label class="form-check-label small" for="cat_@cat.Id">@cat.Name</label>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Hình ảnh</th>
                        <th class="py-3">Tên sản phẩm</th>
                        <th class="py-3">Giá bán</th>
                        <th class="py-3">Tồn kho</th>
                        <th class="py-3">Trạng thái</th>
                        <th class="text-center pe-4 py-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Products?.Items.Count > 0)
                    {
                        foreach (var item in Model.Products.Items)
                        {
                            <tr>
                                <td class="ps-4">
                                    <img src="@item.ImageFilePath" class="rounded object-fit-cover shadow-sm" style="width: 48px; height: 48px;" />
                                </td>
                                <td class="fw-bold text-dark">@item.Name</td>
                                <td class="fw-medium text-success">@item.Price.ToString("N0") đ / @item.ProductUnitName</td>
                                <td class="fw-medium text-muted">@item.Quantity</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success rounded-pill fw-medium">Đang hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger rounded-pill fw-medium">Ngừng KD</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <a asp-page="./ProductDetail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 fw-medium">Chi tiết</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="mb-3 opacity-50" viewBox="0 0 16 16">
                                    <path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1zm3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V4h-3.5zM2 5h12v9a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V5z" />
                                </svg>
                                <br />Không có sản phẩm nào phù hợp.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Products?.TotalPages > 1)
    {
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center bg-white p-3 rounded-4 shadow-sm border border-light">
            <div class="mb-3 mb-md-0 text-muted small">
                Hiển thị trang <span class="fw-bold text-dark">@Model.Products.PageIndex</span> trên
                <span class="fw-bold text-dark">@Model.Products.TotalPages</span>
                (<span class="fw-bold text-dark">@Model.Products.TotalCount</span> sản phẩm)
            </div>
            <div class="d-flex gap-3 align-items-center">
                <div class="btn-group shadow-sm">
                    <button type="submit" form="filterForm" name="RequestData.PageIndex" value="@(Model.Products.PageIndex - 1)" class="btn btn-outline-primary fw-medium @(!Model.Products.HasPreviousPage ? "disabled" : "")">
                        &laquo; Trước
                    </button>
                    <button type="submit" form="filterForm" name="RequestData.PageIndex" value="@(Model.Products.PageIndex + 1)" class="btn btn-outline-primary fw-medium @(!Model.Products.HasNextPage ? "disabled" : "")">
                        Sau &raquo;
                    </button>
                </div>
                <div class="d-flex align-items-center border-start ps-3">
                    <span class="text-muted small me-2 text-nowrap">Đến trang:</span>
                    <div class="input-group input-group-sm" style="width: 120px;">
                        <input name="RequestData.PageIndex" form="filterForm" class="form-control text-center border-primary" min="1" max="@Model.Products.TotalPages" value="@Model.Products.PageIndex" />
                        <button type="submit" form="filterForm" class="btn btn-primary fw-medium">Đi</button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>