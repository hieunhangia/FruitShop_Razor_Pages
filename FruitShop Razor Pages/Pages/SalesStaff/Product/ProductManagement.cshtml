@page
@using Repository.Constants
@model FruitShop_Razor_Pages.Pages.SalesStaff.Product.ProductManagementModel
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Danh sách sản phẩm</h2>
        <div>
            <a asp-page="./PriorityManagement" class="btn btn-outline-primary rounded-pill px-4 me-2 fw-bold">Quản lý ưu tiên</a>
            <a asp-page="./ProductCreate" class="btn btn-primary rounded-pill px-4 fw-bold">Thêm mới</a>
        </div>
    </div>

    <form id="filterForm" method="get" class="card shadow-sm border-0 mb-4">
        <input type="hidden" asp-for="RequestData.PageIndex" id="pageIndexInput" />
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Tên sản phẩm</label>
                    <input type="text" asp-for="RequestData.Filter.SearchName" class="form-control" placeholder="Tìm kiếm...">
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Danh mục</label>
                    <div class="border rounded px-2 py-1 bg-white form-control overflow-auto" style="height: 100px;">
                        @foreach (var cat in Model.Categories)
                        {
                            bool isChecked = Model.RequestData.Filter.CategoryIds.Contains(cat.Id);
                            <div class="form-check form-check-inline mb-0">
                                <input class="form-check-input" type="checkbox" name="RequestData.Filter.CategoryIds" value="@cat.Id" @(isChecked ? "checked" : "")>
                                <label class="form-check-label small">@cat.Name</label>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-muted small fw-bold">Trạng thái</label>
                    <select asp-for="RequestData.Filter.IsActive" class="form-select">
                        <option value="">Tất cả</option>
                        <option value="true">Hoạt động</option>
                        <option value="false">Ngừng KD</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label text-muted small fw-bold">Đơn vị</label>
                    <select asp-for="RequestData.Filter.ProductUnitId" class="form-select">
                        <option value="">Tất cả</option>
                        @foreach (var unit in Model.ProductUnits)
                        {
                            <option value="@unit.Id">@unit.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="button" class="btn btn-success w-100 fw-bold" onclick="document.getElementById('pageIndexInput').value = 1; document.getElementById('filterForm').submit();">Lọc kết quả</button>
                </div>
            </div>
            <div class="row g-3 mt-1">
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Giá từ (đ)</label>
                    <input type="number" asp-for="RequestData.Filter.PriceFrom" class="form-control" placeholder="0">
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Giá đến (đ)</label>
                    <input type="number" asp-for="RequestData.Filter.PriceTo" class="form-control" placeholder="Tối đa">
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Sắp xếp theo</label>
                    <select asp-for="RequestData.SortColumn" class="form-select">
                        <option value="DisplayOrder">Mặc định</option>
                        <option value="Name">Tên sản phẩm</option>
                        <option value="Price">Giá bán</option>
                        <option value="Quantity">Tồn kho</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted small fw-bold">Thứ tự</label>
                    <select asp-for="RequestData.SortDirection" class="form-select">
                        <option value="@SortDirection.Ascending">Tăng dần</option>
                        <option value="@SortDirection.Descending">Giảm dần</option>
                    </select>
                </div>
            </div>
        </div>
    </form>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0 bg-white">
            <thead class="table-light">
                <tr>
                    <th>Hình ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Giá</th>
                    <th>Tồn kho</th>
                    <th>Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Products?.Items.Count > 0)
                {
                    foreach (var item in Model.Products.Items)
                    {
                        <tr>
                            <td><img src="@item.ImageFilePath" class="rounded object-fit-cover" style="width: 50px; height: 50px;" /></td>
                            <td class="fw-bold">@item.Name</td>
                            <td>@item.Price.ToString("N0") đ / @item.ProductUnitName</td>
                            <td>@item.Quantity</td>
                            <td>
                                <span class="badge @(item.IsActive ? "bg-success" : "bg-danger")">
                                    @(item.IsActive ? "Hoạt động" : "Ngừng KD")
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-page="./ProductDetail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3">Chi tiết</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (Model.Products?.TotalPages > 1)
    {
        <div class="d-flex justify-content-end align-items-center mt-4">
            <button type="button" class="btn btn-outline-secondary me-3" @(Model.Products.HasPreviousPage ? "" : "disabled")
                    onclick="document.getElementById('pageIndexInput').value = @(Model.Products.PageIndex - 1); document.getElementById('filterForm').submit();">
                Trước
            </button>

            <span class="me-2 fw-medium">Trang</span>
            <input type="number" class="form-control text-center px-1" value="@Model.Products.PageIndex" min="1" max="@Model.Products.TotalPages" style="width: 65px;"
                   onchange="document.getElementById('pageIndexInput').value = this.value; document.getElementById('filterForm').submit();" />
            <span class="mx-2 fw-medium">/ @Model.Products.TotalPages</span>

            <button type="button" class="btn btn-outline-secondary ms-3" @(Model.Products.HasNextPage ? "" : "disabled")
                    onclick="document.getElementById('pageIndexInput').value = @(Model.Products.PageIndex + 1); document.getElementById('filterForm').submit();">
                Sau
            </button>
        </div>
    }
</div>