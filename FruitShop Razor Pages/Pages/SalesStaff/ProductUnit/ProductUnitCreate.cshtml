@page
@model FruitShop_Razor_Pages.Pages.SalesStaff.ProductUnit.ProductUnitCreateModel
@{
    ViewData["Title"] = "Thêm đơn vị tính";
}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Thêm đơn vị tính</h2>
        <div>
            <button type="submit" form="unitCreateForm" class="btn btn-primary rounded-pill px-4 me-2 fw-bold">Xác nhận thêm</button>
            <a asp-page="./ProductUnitManagement" class="btn btn-outline-secondary rounded-pill px-4">Hủy & Quay lại</a>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <form id="unitCreateForm" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Tên đơn vị tính (vd: Kg, Hộp, Quả)</label>
                    <input asp-for="Unit.Name" class="form-control" required />
                </div>
            </form>
        </div>
    </div>
</div>