@page
@model FruitShop_Razor_Pages.Pages.SalesStaff.ProductUnit.ProductUnitManagementModel
@{
    ViewData["Title"] = "Quản lý đơn vị tính";
}
<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Đơn vị tính</h2>
        <div>
            <a asp-page="./ProductUnitCreate" class="btn btn-primary rounded-pill px-4 fw-bold">Thêm mới</a>
            <a asp-page="/SalesStaff/Dashboard/Index" class="btn btn-outline-secondary rounded-pill px-4 ms-2">Quay lại Dashboard</a>
        </div>
    </div>
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 bg-white">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Tên đơn vị tính</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Units)
                    {
                        <tr>
                            <td class="fw-bold text-muted">#@item.Id</td>
                            <td class="fw-bold">@item.Name</td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-page="./ProductUnitEdit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3">Sửa</a>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@item.Id" onsubmit="return confirm('Bạn có chắc muốn xóa đơn vị này?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Xóa</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>