@using System.Security.Claims
@using Repository.Constants
@using Repository.Models.Users
@using Service.Customer
@inject SignInManager<User> SignInManager
@inject CartService CartService

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - FruitShop</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/FruitShop_Razor_Pages.styles.css" asp-append-version="true"/>
</head>
<body class="d-flex flex-column min-vh-100 bg-light-green">
<header>
    <nav class="navbar navbar-expand-md navbar-light bg-white border-bottom shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand text-success fw-bold navbar-brand-fruit d-flex align-items-center" asp-page="/Index">
                <span class="fs-2 me-2">🍏</span> FruitShop
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Mở menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                <ul class="navbar-nav align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item dropdown me-2">
                            <a class="nav-link dropdown-toggle fw-bold text-success user-greeting rounded-pill px-3"
                               href="#" id="accountDropdown" role="button" data-bs-toggle="dropdown"
                               aria-expanded="false">
                                @User.Identity!.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3 mt-2"
                                aria-labelledby="accountDropdown">
                                <li>
                                    <a class="dropdown-item fw-medium py-2" asp-page="/Account/ManageAccount">Quản lý
                                        tài khoản</a>
                                </li>
                                <li>
                                    <hr class="dropdown-divider">
                                </li>
                                <li>
                                    <form method="post" asp-controller="Account" asp-action="Logout"
                                          class="m-0 px-2 pb-1">
                                        <button type="submit"
                                                class="btn btn-outline-danger w-100 rounded-3 fw-bold btn-sm">Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                        @if (User.IsInRole(Role.Customer))
                        {
                            var cartCount = await CartService.CountCartItemsAsync(int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!));
                            <li class="nav-item ms-2 mt-2 mt-md-0">
                                <a asp-page="/Customer/Cart"
                                   class="btn btn-outline-success position-relative rounded-pill px-3 d-flex align-items-center"
                                   aria-label="Giỏ hàng">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor"
                                         viewBox="0 0 16 16">
                                        <path
                                            d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .49.598l-1 5a.5.5 0 0 1-.465.401l-9.397.472L4.415 11H13a.5.5 0 0 1 0 1H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l.84 4.479 9.144-.459L13.89 4zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4m-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                                    </svg>
                                    @if (cartCount > 0)
                                    {
                                        <span
                                            class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger shadow-sm border border-white">
                                            @cartCount
                                            <span class="visually-hidden">sản phẩm trong giỏ</span>
                                        </span>
                                    }
                                </a>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="nav-item me-3">
                            <a class="nav-link fw-medium text-dark px-0" asp-page="/Account/Register">Đăng ký</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-fruit shadow-sm" asp-page="/Account/Login">Đăng nhập</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container flex-grow-1 main-content">
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted bg-white mt-auto py-4">
    <div class="container text-center">
        &copy; 2026 - <span class="text-success fw-bold">FruitShop</span>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>