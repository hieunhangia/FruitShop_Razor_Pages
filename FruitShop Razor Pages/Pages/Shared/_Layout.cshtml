@using Repository.Models.Users
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - FruitShop</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/FruitShop_Razor_Pages.styles.css" asp-append-version="true"/>
</head>
<body class="d-flex flex-column min-vh-100 bg-light-green">
<header>
    <nav class="navbar navbar-expand-md navbar-light bg-white border-bottom shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand text-success fw-bold navbar-brand-fruit d-flex align-items-center" asp-page="/Index">
                <span class="fs-2 me-2">🍏</span> FruitShop
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse"
                    data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Mở menu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                <ul class="navbar-nav align-items-center">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item me-3">
                            <div class="user-greeting d-flex align-items-center">
                                <span class="text-muted me-1 small">Xin chào,</span>
                                <span class="fw-bold text-success">@UserManager.GetUserName(User)</span>
                            </div>
                        </li>
                        <li class="nav-item">
                            <form method="post" asp-controller="Account" asp-action="Logout" class="m-0">
                                <button type="submit" class="btn btn-outline-danger rounded-pill px-4 btn-sm">Đăng
                                    xuất
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-3">
                            <a class="nav-link fw-medium text-dark px-0" asp-page="/Account/Register">Đăng ký</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-fruit shadow-sm" asp-page="/Account/Login">Đăng nhập</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container flex-grow-1 main-content">
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted bg-white mt-auto py-4">
    <div class="container text-center">
        &copy; 2026 - <span class="text-success fw-bold">FruitShop</span>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>