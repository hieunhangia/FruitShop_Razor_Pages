@page
@using Repository.Constants
@using Repository.Models.Orders
@model FruitShop_Razor_Pages.Pages.Shipper.ShipperHistoryModel

@{
    ViewData["Title"] = "Lịch sử đơn hàng của bạn";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-success mb-0">Lịch sử đơn hàng</h2>
    </div>

    <form method="get">
        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3 d-flex align-items-center text-dark">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="me-2 text-success" viewBox="0 0 16 16">
                        <path d="M1.5 1.5A.5.5 0 0 1 2 1h12a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-.128.334L10 8.692V13.5a.5.5 0 0 1-.342.474l-3 1A.5.5 0 0 1 6 14.5V8.692L1.628 3.834A.5.5 0 0 1 1.5 3.5v-2zm1 .5v1.308l4.372 4.858A.5.5 0 0 1 7 8.5v5.306l2-.666V8.5a.5.5 0 0 1 .128-.334L13.5 3.308V2h-11z" />
                    </svg>
                    Bộ lọc tìm kiếm đơn hàng
                </h5>
                <div asp-validation-summary="All" class="text-danger mb-3 small fw-medium" role="alert"></div>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Mã đơn hàng</label>
                        <input asp-for="PagedAndSortedRequest.Filter.SearchId" class="form-control rounded-3" placeholder="Nhập mã đơn cần tìm..." />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Trạng thái đơn</label>
                        <select asp-for="PagedAndSortedRequest.Filter.OrderStatus" class="form-select rounded-3">
                            <option value="">Tất cả trạng thái</option>
                            <option value="@OrderStatus.PendingConfirmation">Chờ xác nhận</option>
                            <option value="@OrderStatus.PendingPayment">Chờ thanh toán</option>
                            <option value="@OrderStatus.Processing">Đang chuẩn bị hàng</option>
                            <option value="@OrderStatus.Shipping">Đang giao hàng</option>
                            <option value="@OrderStatus.Delivered">Đã giao hàng</option>
                            <option value="@OrderStatus.Cancelled">Đã hủy</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Phương thức thanh toán</label>
                        <select asp-for="PagedAndSortedRequest.Filter.PaymentMethod" class="form-select rounded-3">
                            <option value="">Tất cả phương thức</option>
                            <option value="@PaymentMethod.CashOnDelivery">Thanh toán khi nhận hàng</option>
                            <option value="@PaymentMethod.QRCode">Chuyển khoản QR</option>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Từ ngày đặt</label>
                        <input type="date" asp-for="PagedAndSortedRequest.Filter.StartDate" class="form-control rounded-3" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Đến ngày đặt</label>
                        <input type="date" asp-for="PagedAndSortedRequest.Filter.EndDate" class="form-control rounded-3" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Khoảng giá tổng tiền (VNĐ)</label>
                        <div class="input-group">
                            <input asp-for="PagedAndSortedRequest.Filter.StartTotalAmount" class="form-control rounded-start-3" placeholder="Từ" />
                            <span class="input-group-text bg-light border-start-0 border-end-0">-</span>
                            <input asp-for="PagedAndSortedRequest.Filter.EndTotalAmount" class="form-control rounded-end-3" placeholder="Đến" />
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Sắp xếp theo</label>
                        <select asp-for="PagedAndSortedRequest.SortColumn" class="form-select rounded-3">
                            <option value="@nameof(Order.Id)">Mã đơn hàng</option>
                            <option value="@nameof(Order.OrderDate)">Ngày đặt hàng</option>
                            <option value="@nameof(Order.OrderStatus)">Trạng thái đơn</option>
                            <option value="@nameof(Order.TotalAmount)">Tổng số tiền</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small fw-medium text-muted mb-1">Thứ tự hiển thị</label>
                        <select asp-for="PagedAndSortedRequest.SortDirection" class="form-select rounded-3">
                            <option value="@SortDirection.Ascending">Tăng dần</option>
                            <option value="@SortDirection.Descending">Giảm dần</option>
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <button type="submit" name="isSearch" value="true" class="btn btn-success rounded-3 w-100 fw-medium shadow-sm btn-fruit">
                            Áp dụng bộ lọc dữ liệu
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3">Mã Đơn hàng</th>
                            <th class="py-3">Ngày đặt</th>
                            <th class="py-3">Trạng thái</th>
                            <th class="py-3">Thanh toán</th>
                            <th class="py-3 text-end">Tổng tiền</th>
                            <th class="text-center pe-4 py-3">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.PagedAndSortedResult?.Items.Any() ?? false)
                        {
                            foreach (var order in Model.PagedAndSortedResult.Items)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-dark">#@order.Id</td>
                                    <td>@order.OrderDate.ToString("HH:mm dd/MM/yyyy")</td>
                                    <td>
                                        @switch (order.OrderStatus)
                                        {
                                            case OrderStatus.PendingConfirmation:
                                                <span class="badge bg-warning text-dark rounded-pill fw-medium">Chờ xác nhận</span>
                                                break;
                                            case OrderStatus.PendingPayment:
                                                <span class="badge bg-info text-dark rounded-pill fw-medium">Chờ thanh toán</span>
                                                break;
                                            case OrderStatus.Processing:
                                                <span class="badge bg-primary rounded-pill fw-medium">Đang chuẩn bị</span>
                                                break;
                                            case OrderStatus.Shipping:
                                                <span class="badge bg-info rounded-pill fw-medium">Đang giao</span>
                                                break;
                                            case OrderStatus.Delivered:
                                                <span class="badge bg-success rounded-pill fw-medium">Đã giao hàng</span>
                                                break;
                                            case OrderStatus.Cancelled:
                                                <span class="badge bg-danger rounded-pill fw-medium">Đã hủy</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary rounded-pill fw-medium">Không xác định</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        @if (order.PaymentMethod == PaymentMethod.CashOnDelivery)
                                        {
                                            <span class="text-dark fw-medium d-flex align-items-center">💵 Tiền mặt (COD)</span>
                                        }
                                        else
                                        {
                                            <span class="text-primary fw-medium d-flex align-items-center">📱 Chuyển khoản QR</span>
                                        }
                                    </td>
                                    <td class="text-end fw-bold text-success">@order.TotalAmount.ToString("N0") đ</td>
                                    <td class="text-center pe-4">
                                        <a asp-page="OrderDetails" asp-route-id="@order.Id"
                                           class="btn btn-sm btn-outline-success rounded-pill px-3 fw-medium">Chi tiết</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    Không tìm thấy lịch sử đơn hàng nào phù hợp với bộ lọc.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.PagedAndSortedResult?.TotalPages > 1)
        {
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center bg-white p-3 rounded-4 shadow-sm border border-light">
                <div class="mb-3 mb-md-0 text-muted small">
                    Hiển thị trang <span class="fw-bold text-dark">@Model.PagedAndSortedResult.PageIndex</span> trên
                    <span class="fw-bold text-dark">@Model.PagedAndSortedResult.TotalPages</span>
                </div>
                <div class="d-flex gap-3 align-items-center">
                    <div class="btn-group shadow-sm">
                        @if (Model.PagedAndSortedResult.HasPreviousPage)
                        {
                            <button type="submit" name="PagedAndSortedRequest.PageIndex" value="@(Model.PagedAndSortedResult.PageIndex - 1)" class="btn btn-outline-success fw-medium">&laquo; Trước</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-success disabled fw-medium">&laquo; Trước</button>
                        }

                        @if (Model.PagedAndSortedResult.HasNextPage)
                        {
                            <button type="submit" name="PagedAndSortedRequest.PageIndex" value="@(Model.PagedAndSortedResult.PageIndex + 1)" class="btn btn-outline-success fw-medium">Sau &raquo;</button>
                        }
                        else
                        {
                            <button type="button" class="btn btn-outline-success disabled fw-medium">Sau &raquo;</button>
                        }
                    </div>
                    <div class="d-flex align-items-center border-start ps-3">
                        <span class="text-muted small me-2 text-nowrap">Đến trang:</span>
                        <div class="input-group input-group-sm" style="width: 120px;">
                            <input asp-for="PagedAndSortedRequest.PageIndex" class="form-control text-center border-success" min="1" max="@Model.PagedAndSortedResult.TotalPages" value="@Model.PagedAndSortedResult.PageIndex" />
                            <button type="submit" class="btn btn-success fw-medium">Đi</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}