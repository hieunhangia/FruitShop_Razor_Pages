@page
@model FruitShop_Razor_Pages.Pages.Shipper.ShipperHistoryModel
@{
    ViewData["Title"] = "Lịch sử giao hàng";
}

<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a href="/Shipper/Dashboard"
           class="btn btn-outline-secondary rounded-pill me-3 d-flex align-items-center fw-bold shadow-sm">
            <i class="bi bi-arrow-left me-2"></i> Quay lại
        </a>
        <h2 class="mb-0 fw-bold text-dark">Lịch Sử Giao Hàng Thành Công</h2>
    </div>

    <!-- Filter Card -->
    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-4">
            <h5 class="card-title fw-bold text-success mb-3 d-flex align-items-center">
                <i class="bi bi-funnel me-2"></i> Bộ lọc tìm kiếm
            </h5>
            <form method="get">
                <div class="row g-3 align-items-end">
                    <div class="col-md-4">
                        <label class="form-label small fw-bold text-secondary">Mã đơn hàng</label>
                        <input type="text" name="RequestData.Filter.SearchTerm"
                               value="@Model.RequestData.Filter?.SearchTerm" class="form-control rounded-3"
                               placeholder="Nhập mã đơn..."/>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-secondary">Từ ngày</label>
                        <input type="date" name="RequestData.Filter.FromDate"
                               value="@(Model.RequestData.Filter?.FromDate?.ToString("yyyy-MM-dd"))"
                               class="form-control rounded-3"/>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label small fw-bold text-secondary">Đến ngày</label>
                        <input type="date" name="RequestData.Filter.ToDate"
                               value="@(Model.RequestData.Filter?.ToDate?.ToString("yyyy-MM-dd"))"
                               class="form-control rounded-3"/>
                    </div>

                    <div class="col-md-2">
                        <input type="hidden" name="RequestData.PageIndex" value="1"/>
                        <button type="submit"
                                class="btn btn-success fw-bold rounded-3 w-100 shadow-sm d-flex justify-content-center align-items-center py-2">
                            <i class="bi bi-search me-2"></i> Áp dụng
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Orders Table Card -->
    <div class="card border-0 shadow-sm rounded-4">
        <div
            class="card-header bg-white border-bottom p-4 d-flex justify-content-between align-items-center rounded-top-4">
            <h5 class="mb-0 fw-bold text-dark d-flex align-items-center">
                <i class="bi bi-check-circle text-success me-2"></i> Danh sách đơn hàng hoàn thành
            </h5>
            <span class="badge bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill fw-bold fs-6">
                Tổng cộng: @Model.PagedResult.TotalCount đơn
            </span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                    <tr>
                        @{
                            string nextIdDir = (Model.RequestData.SortColumn?.ToLower() == "id" && Model.RequestData.SortDirection == Repository.Constants.SortDirection.Descending) ? "Ascending" : "Descending";
                            string nextDateDir = (Model.RequestData.SortColumn?.ToLower() == "orderdate" && Model.RequestData.SortDirection == Repository.Constants.SortDirection.Descending) ? "Ascending" : "Descending";
                            string nextAmountDir = (Model.RequestData.SortColumn?.ToLower() == "totalamount" && Model.RequestData.SortDirection == Repository.Constants.SortDirection.Descending) ? "Ascending" : "Descending";

                            string GetArrow(string column)
                            {
                                if (Model.RequestData.SortColumn?.ToLower() != column.ToLower()) return "";
                                return Model.RequestData.SortDirection == Repository.Constants.SortDirection.Descending ? " ▼" : " ▲";
                            }
                        }
                        <th class="px-4 py-3 border-bottom-0 text-nowrap">
                            <a href="?RequestData.Filter.SearchTerm=@Model.RequestData.Filter?.SearchTerm&RequestData.Filter.FromDate=@Model.RequestData.Filter?.FromDate?.ToString("yyyy-MM-dd")&RequestData.Filter.ToDate=@Model.RequestData.Filter?.ToDate?.ToString("yyyy-MM-dd")&RequestData.SortColumn=id&RequestData.SortDirection=@nextIdDir&RequestData.PageIndex=1"
                               class="text-secondary text-decoration-none fw-bold text-uppercase small">
                                Mã đơn hàng <span class="text-success">@GetArrow("id")</span>
                            </a>
                        </th>
                        <th class="px-4 py-3 border-bottom-0 text-nowrap">
                            <a href="?RequestData.Filter.SearchTerm=@Model.RequestData.Filter?.SearchTerm&RequestData.Filter.FromDate=@Model.RequestData.Filter?.FromDate?.ToString("yyyy-MM-dd")&RequestData.Filter.ToDate=@Model.RequestData.Filter?.ToDate?.ToString("yyyy-MM-dd")&RequestData.SortColumn=orderdate&RequestData.SortDirection=@nextDateDir&RequestData.PageIndex=1"
                               class="text-secondary text-decoration-none fw-bold text-uppercase small">
                                Ngày đặt hàng <span class="text-success">@GetArrow("orderdate")</span>
                            </a>
                        </th>
                        <th class="px-4 py-3 border-bottom-0 text-nowrap">
                            <a href="?RequestData.Filter.SearchTerm=@Model.RequestData.Filter?.SearchTerm&RequestData.Filter.FromDate=@Model.RequestData.Filter?.FromDate?.ToString("yyyy-MM-dd")&RequestData.Filter.ToDate=@Model.RequestData.Filter?.ToDate?.ToString("yyyy-MM-dd")&RequestData.SortColumn=totalamount&RequestData.SortDirection=@nextAmountDir&RequestData.PageIndex=1"
                               class="text-secondary text-decoration-none fw-bold text-uppercase small">
                                Tổng tiền <span class="text-success">@GetArrow("totalamount")</span>
                            </a>
                        </th>
                        <th class="px-4 py-3 border-bottom-0 fw-bold text-secondary text-uppercase small">Phương thức
                        </th>
                        <th class="px-4 py-3 border-bottom-0 fw-bold text-secondary text-uppercase small text-end">Thao
                            tác
                        </th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (!Model.PagedResult.Items.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="text-muted fst-italic">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    Bạn chưa có đơn hàng nào hoàn thành trong bộ lọc này.
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var order in Model.PagedResult.Items)
                        {
                            <tr>
                                <td class="px-4 py-3">
                                    <span class="fw-bold text-dark">#@order.Id</span>
                                </td>
                                <td class="px-4 py-3 text-secondary">
                                    <i class="bi bi-calendar3 me-1"></i> @order.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="px-4 py-3">
                                    <span class="fw-bold text-danger">@order.TotalAmount.ToString("N0") đ</span>
                                </td>
                                <td class="px-4 py-3">
                                        <span class="badge bg-light text-dark border px-2 py-1 rounded-2">
                                            @switch (order.PaymentMethod)
                                            {
                                                case Repository.Constants.PaymentMethod.CashOnDelivery:
                                                    <span class="text-dark fw-medium d-flex align-items-center">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                     fill="currentColor" class="me-2 text-success" viewBox="0 0 16 16">
                                                    <path
                                                        d="M1 3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1H1zm7 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4z"/>
                                                    <path
                                                        d="M0 5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1V5zm3 0a2 2 0 0 1-2 2v4a2 2 0 0 1 2 2h10a2 2 0 0 1 2-2V7a2 2 0 0 1-2-2H3z"/>
                                                </svg>
                                                Tiền mặt (COD)
                                            </span>
                                                    break;
                                                case Repository.Constants.PaymentMethod.QRCode:
                                                    <span class="text-dark fw-medium d-flex align-items-center">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                                                     fill="currentColor" class="me-2 text-primary" viewBox="0 0 16 16">
                                                    <path d="M2 2h2v2H2V2Z"/>
                                                    <path d="M6 0v6H0V0h6ZM5 1H1v4h4V1ZM4 12H2v2h2v-2Z"/>
                                                    <path d="M6 10v6H0v-6h6Zm-5 1v4h4v-4H1Zm11-9h2v2h-2V2Z"/>
                                                    <path
                                                        d="M10 0v6h6V0h-6Zm5 1v4h-4V1h4ZM8 1V0h1v2H8v2H7V1h1Zm0 5V4h1v2H8ZM6 8V7h1V6h1v2h1V7h5v1h-4v1H7V8H6Zm0 0v1H2V8H1v1H0V7h3v1h3Zm10 1h-1V7h1v2Zm-1 0h-1v2h2v-1h-1V9Zm-4 0h2v1h-1v1h-1V9Zm2 3v-1h-1v1h-1v1H9v1h3v-2h1Zm0 0h3v1h-2v1h-1v-2Zm-4-1v1h1v-2H7v1h2Z"/>
                                                    <path d="M7 12h1v3h4v1H7v-4Zm9 2v2h-3v-1h2v-1h1Z"/>
                                                </svg>
                                                Chuyển khoản QR
                                            </span>
                                                    break;
                                                default:
                                                    <span>Không xác định</span>
                                                    break;
                                            }
                                        </span>
                                </td>
                                <td class="px-4 py-3 text-end">
                                    <a href="/Shipper/OrderDetails?id=@order.Id"
                                       class="btn btn-sm btn-outline-success rounded-pill px-3 fw-bold d-inline-flex align-items-center">
                                        Xem lại chi tiết <i class="bi bi-chevron-right ms-1 small"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>

        @if (Model.PagedResult.TotalPages > 1)
        {
            <div class="card-footer bg-white border-top-0 p-4 rounded-bottom-4">
                <nav aria-label="Page navigation" class="d-flex justify-content-center mb-0">
                    <ul class="pagination pagination-sm mb-0 shadow-sm rounded-pill overflow-hidden">
                        <li class="page-item @(!Model.PagedResult.HasPreviousPage ? "disabled" : "")">
                            <a class="page-link border-0 text-success fw-bold px-3 py-2"
                               href="?RequestData.Filter.SearchTerm=@Model.RequestData.Filter?.SearchTerm&RequestData.Filter.FromDate=@Model.RequestData.Filter?.FromDate?.ToString("yyyy-MM-dd")&RequestData.Filter.ToDate=@Model.RequestData.Filter?.ToDate?.ToString("yyyy-MM-dd")&RequestData.SortColumn=@Model.RequestData.SortColumn&RequestData.SortDirection=@Model.RequestData.SortDirection&RequestData.PageIndex=@(Model.PagedResult.PageIndex - 1)">
                                &laquo; Trước
                            </a>
                        </li>
                        @for (int i = 1; i <= Model.PagedResult.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PagedResult.PageIndex ? "active" : "")">
                                <a class="page-link border-0 @(i == Model.PagedResult.PageIndex ? "bg-success text-white" : "text-success fw-bold") px-3 py-2"
                                   href="?RequestData.Filter.SearchTerm=@Model.RequestData.Filter?.SearchTerm&RequestData.Filter.FromDate=@Model.RequestData.Filter?.FromDate?.ToString("yyyy-MM-dd")&RequestData.Filter.ToDate=@Model.RequestData.Filter?.ToDate?.ToString("yyyy-MM-dd")&RequestData.SortColumn=@Model.RequestData.SortColumn&RequestData.SortDirection=@Model.RequestData.SortDirection&RequestData.PageIndex=@i">@i</a>
                            </li>
                        }
                        <li class="page-item @(!Model.PagedResult.HasNextPage ? "disabled" : "")">
                            <a class="page-link border-0 text-success fw-bold px-3 py-2"
                               href="?RequestData.Filter.SearchTerm=@Model.RequestData.Filter?.SearchTerm&RequestData.Filter.FromDate=@Model.RequestData.Filter?.FromDate?.ToString("yyyy-MM-dd")&RequestData.Filter.ToDate=@Model.RequestData.Filter?.ToDate?.ToString("yyyy-MM-dd")&RequestData.SortColumn=@Model.RequestData.SortColumn&RequestData.SortDirection=@Model.RequestData.SortDirection&RequestData.PageIndex=@(Model.PagedResult.PageIndex + 1)">
                                Sau &raquo;
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>